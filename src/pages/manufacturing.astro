---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faCalendarCheck, faBoxesStacked, faClipboardCheck, faWrench, faHandshake, faChartLine, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconScheduling = icon(faCalendarCheck).html[0];
const iconInventory = icon(faBoxesStacked).html[0];
const iconQuality = icon(faClipboardCheck).html[0];
const iconMaintenance = icon(faWrench).html[0];
const iconVendor = icon(faHandshake).html[0];
const iconReporting = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Employees for Manufacturing">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI for Manufacturing</span></div>
				<h1 class="hero-heading">Run Your Plant. <span class="accent">Without Running Yourself Ragged.</span></h1>
				<p class="hero-sub">
					An AI employee for manufacturing that handles production scheduling, inventory management, and quality control&nbsp;&mdash; so you can focus on continuous improvement.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">20%</span>
					<span class="hero-stat-label">Increase in overall equipment effectiveness</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Production scheduling is a constant firefight</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Stockouts and excess inventory hurt margins</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Quality issues slip through until too late</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Maintenance is reactive, not preventive</span></div>
				</div>

				<p class="problem-callout">What if schedules optimized themselves, materials arrived just in time, and quality issues got caught before they shipped?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI MANUFACTURING EMPLOYEE DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Manufacturing Employee Does</h2>
				<p class="section-subtext">Everything that keeps your plant from running smoothly&nbsp;&mdash; planning, tracking, coordinating&nbsp;&mdash; handled autonomously.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconScheduling}></div>
						<h3 class="role-card-title">Production Scheduling</h3>
						<p class="role-card-desc">Optimizes production schedules based on orders, capacity, and constraints. Reduces changeovers and maximizes throughput.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconInventory}></div>
						<h3 class="role-card-title">Inventory Management</h3>
						<p class="role-card-desc">Tracks raw materials and finished goods. Generates purchase orders at optimal reorder points automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconQuality}></div>
						<h3 class="role-card-title">Quality Control</h3>
						<p class="role-card-desc">Tracks quality metrics, manages non-conformances, and coordinates corrective actions. Maintains compliance documentation.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconMaintenance}></div>
						<h3 class="role-card-title">Maintenance Coordination</h3>
						<p class="role-card-desc">Schedules preventive maintenance, tracks work orders, and coordinates with production to minimize downtime.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconVendor}></div>
						<h3 class="role-card-title">Vendor Management</h3>
						<p class="role-card-desc">Manages supplier relationships, tracks delivery performance, and negotiates based on data-driven insights.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReporting}></div>
						<h3 class="role-card-title">Production Reporting</h3>
						<p class="role-card-desc">Generates OEE reports, tracks KPIs, and provides real-time visibility into plant performance.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== BUILT FOR MANUFACTURING ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Built for Manufacturing</h2>
				<p class="section-subtext">Deep understanding of manufacturing operations, from job shop to continuous process.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Production Planning</h3>
						<ul class="value-list">
							<li>Demand-driven scheduling</li>
							<li>Capacity planning and optimization</li>
							<li>Work order management</li>
							<li>Shop floor coordination</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Supply Chain</h3>
						<ul class="value-list">
							<li>Material requirements planning</li>
							<li>Purchase order automation</li>
							<li>Supplier performance tracking</li>
							<li>Lead time management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Quality Management</h3>
						<ul class="value-list">
							<li>Inspection scheduling and tracking</li>
							<li>Non-conformance management</li>
							<li>CAPA coordination</li>
							<li>Audit trail maintenance</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Plant Operations</h3>
						<ul class="value-list">
							<li>Preventive maintenance scheduling</li>
							<li>Equipment downtime tracking</li>
							<li>Safety compliance monitoring</li>
							<li>Shift handoff coordination</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">20%</span>
						<span class="stat-label">Increase in OEE</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">35%</span>
						<span class="stat-label">Reduction in inventory carrying costs</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">50%</span>
						<span class="stat-label">Less time on production planning</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">0</span>
						<span class="stat-label">Stockouts due to planning errors</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Systems</h3>
						<p class="step-desc">Integrate with your ERP, MES, and quality systems. We work with SAP, Oracle, and other major platforms.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Your Operations</h3>
						<p class="step-desc">Define production rules, quality standards, and maintenance schedules. Your AI learns your plant's rhythms.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Optimize Production</h3>
						<p class="step-desc">Schedules optimize automatically, materials arrive on time, and quality stays consistent. You focus on improvement.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Optimize Your Operations?</h2>
				<p class="final-cta-sub">
					Tell us about your plant and current challenges. We'll show you exactly how AI can improve throughput and reduce costs.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
