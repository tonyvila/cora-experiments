---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faUsers, faSitemap, faCalendarDays, faChartLine, faGauge, faMoneyCheckDollar, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconTeamView = icon(faUsers).html[0];
const iconRouting = icon(faSitemap).html[0];
const iconScheduling = icon(faCalendarDays).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconCapacity = icon(faGauge).html[0];
const iconCost = icon(faMoneyCheckDollar).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — Workforce Management">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI Workforce Management</span></div>
				<h1 class="hero-heading">Manage Humans and AI. <span class="accent">In One Platform.</span></h1>
				<p class="hero-sub">
					Workforce management for the hybrid era. Route work, schedule capacity, and optimize performance across human and AI employees&mdash;all in one dashboard.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">35%</span>
					<span class="hero-stat-label">Increase in team productivity</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">AI employees live in separate systems from human teams</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No unified view of total workforce capacity</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Work routing between humans and AI is manual</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Can't compare performance across worker types</span></div>
				</div>

				<p class="problem-callout">What if you could manage your entire workforce&mdash;human and AI&mdash;in one platform, with intelligent routing and unified analytics?</p>
			</div>
		</section>

		<!-- ===== ONE TEAM. ONE PLATFORM. ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">One Team. One Platform.</h2>
				<p class="section-subtext">Everything you need to manage the workforce of the future.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTeamView}></div>
						<h3 class="role-card-title">Unified Team View</h3>
						<p class="role-card-desc">See human and AI employees in one dashboard. Track capacity, assignments, and performance across your entire workforce.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRouting}></div>
						<h3 class="role-card-title">Smart Task Routing</h3>
						<p class="role-card-desc">Automatically route work to the right resource&mdash;human or AI&mdash;based on complexity, urgency, and availability.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconScheduling}></div>
						<h3 class="role-card-title">Hybrid Scheduling</h3>
						<p class="role-card-desc">Schedule human shifts and AI capacity together. Optimize coverage across time zones and work types.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Performance Analytics</h3>
						<p class="role-card-desc">Compare human and AI performance on the same metrics. Identify where each excels and optimize the mix.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCapacity}></div>
						<h3 class="role-card-title">Capacity Planning</h3>
						<p class="role-card-desc">Forecast workload and plan the right mix of human and AI capacity. Model scenarios before you commit.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCost}></div>
						<h3 class="role-card-title">Cost Optimization</h3>
						<p class="role-card-desc">See the true cost per task for human vs. AI workers. Make data-driven decisions about workforce composition.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== BUILT FOR HYBRID TEAMS ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Built for Hybrid Teams</h2>
				<p class="section-subtext">Every capability designed for organizations with both human and AI workers.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Team Management</h3>
						<ul class="value-list">
							<li>Unified org chart for humans and AI</li>
							<li>Role-based access and permissions</li>
							<li>Manager dashboards and reports</li>
							<li>Team capacity visualization</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Work Distribution</h3>
						<ul class="value-list">
							<li>Intelligent task assignment</li>
							<li>Skill-based routing</li>
							<li>Workload balancing</li>
							<li>Escalation management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Scheduling</h3>
						<ul class="value-list">
							<li>Shift planning with AI coverage</li>
							<li>Time-off management</li>
							<li>Overtime optimization</li>
							<li>Multi-timezone coordination</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Analytics</h3>
						<ul class="value-list">
							<li>Productivity metrics by worker type</li>
							<li>Quality comparisons</li>
							<li>Cost per task analysis</li>
							<li>Trend forecasting</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">35%</span>
						<span class="stat-label">Increase in team productivity</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">50%</span>
						<span class="stat-label">Reduction in task routing time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">100%</span>
						<span class="stat-label">Visibility into workforce capacity</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Coverage without night shifts</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Map Your Workforce</h3>
						<p class="step-desc">Import your current team structure and add AI employees. Define roles, skills, and reporting relationships.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Routing</h3>
						<p class="step-desc">Set rules for which work goes to humans vs. AI. Define escalation paths and approval workflows.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Optimize Continuously</h3>
						<p class="step-desc">Use analytics to refine the mix. Move work to AI where it excels, keep humans where they add unique value.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready for Hybrid Workforce Management?</h2>
				<p class="final-cta-sub">
					Tell us about your team composition. We'll show you how unified management improves productivity and reduces costs.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
