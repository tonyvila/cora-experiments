					<p style="font-size: 1.0625rem; color: var(--v2-text-secondary); line-height: 1.7;" id="acceptance-message"></p>
					<p style="font-size: 0.875rem; color: var(--v2-text-muted); margin-top: 1.5rem;">A signed PDF will be sent to your email shortly.</p>
				</div>

				<!-- ALREADY ACCEPTED STATE -->
				<div id="acceptance-already" style="display: none; text-align: center; padding: 3rem 1rem;">
					<div style="width: 56px; height: 56px; border-radius: 50%; background: var(--v2-accent); display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					</div>
					<h2 style="font-family: var(--v2-font-heading); font-size: 1.75rem; color: var(--v2-text); margin-bottom: 0.75rem;">Proposal Accepted</h2>
					<p style="font-size: 1.0625rem; color: var(--v2-text-secondary); line-height: 1.7;" id="already-accepted-message">This proposal has already been accepted.</p>
					<p style="font-size: 0.875rem; color: var(--v2-text-muted); margin-top: 1.5rem;">A signed copy has been sent to both parties. If you need assistance, contact <a href="mailto:vinay@cora.st" style="color: var(--v2-accent);">vinay@cora.st</a>.</p>
				</div>
			</div>

		<script>
				(function() {
					var slug = document.querySelector('input[name="proposal_slug"]').value;

					// Check acceptance status on page load
					fetch('https://vp58.app.n8n.cloud/webhook/proposal-status?slug=' + encodeURIComponent(slug))
						.then(function(r) { return r.json(); })
						.then(function(status) {
							if (status.accepted) {
								document.getElementById('acceptance-form-wrap').style.display = 'none';
								document.getElementById('acceptance-already').style.display = 'block';
								var msg = 'This proposal was accepted';
								if (status.accepted_at) {
									var d = new Date(status.accepted_at);
									msg += ' on ' + d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
								}
								if (status.signer_name) msg += ' by ' + status.signer_name;
								msg += '.';
								document.getElementById('already-accepted-message').textContent = msg;
							}
						})
						.catch(function() { /* silently proceed with form */ });

					// Form submission handler
					document.getElementById('proposal-acceptance-form').addEventListener('submit', async function(e) {
						e.preventDefault();
						var btn = document.getElementById('accept-btn');
						if (btn.disabled) return;
						btn.disabled = true;

						var form = e.target;
						var formData = new FormData(form);
						var data = Object.fromEntries(formData.entries());
						data.accepted_at = new Date().toISOString();
						data.proposal_url = window.location.href;

						document.getElementById('acceptance-form-wrap').style.display = 'none';
						document.getElementById('acceptance-loading').style.display = 'block';

						try {
							var res = await fetch('https://vp58.app.n8n.cloud/webhook/proposal-acceptance', {
								method: 'POST',
								headers: { 'Content-Type': 'application/json' },
								body: JSON.stringify(data)
							});
							var result = await res.json();
							document.getElementById('acceptance-loading').style.display = 'none';

							if (result.error === 'already_accepted') {
								document.getElementById('acceptance-already').style.display = 'block';
								var msg = 'This proposal was already accepted';
								if (result.accepted_at) {
									var d = new Date(result.accepted_at);
									msg += ' on ' + d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
								}
								if (result.signer_name) msg += ' by ' + result.signer_name;
								msg += '.';
								document.getElementById('already-accepted-message').textContent = msg;
							} else if (res.ok) {
								document.getElementById('acceptance-success').style.display = 'block';
								document.getElementById('acceptance-message').textContent =
									"We're excited to help " + data.client_name + " on their AI Transformation journey.";
							} else {
								throw new Error(result.message || 'Submission failed');
							}
						} catch (err) {
							document.getElementById('acceptance-loading').style.display = 'none';
							document.getElementById('acceptance-form-wrap').style.display = 'block';
							btn.disabled = false;
							btn.textContent = 'Try Again';
							alert('Something went wrong. Please try again or contact vinay@cora.st.');
						}
					});
				})();
			</script>
		</div>
	</section>

	<!-- ===== CONTACT ===== -->
	<section class="final-cta">
		<div class="container final-cta-container">
			<h2 class="final-cta-heading">Questions?</h2>
			<p class="final-cta-sub">Contact Vinay Patankar at <a href="mailto:vinay@cora.st" style="color: var(--v2-accent); text-decoration: none;">vinay@cora.st</a></p>
			<p style="font-size: 0.9375rem; color: var(--v2-text-muted);">Process Street, Inc. &middot; <a href="https://www.cora.st" style="color: var(--v2-text-muted); text-decoration: underline;">www.cora.st</a></p>
		</div>
	</section>

</main>

