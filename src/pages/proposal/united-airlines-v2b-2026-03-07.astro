---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
	title="Cora — Proposal for United Airlines"
	description="AI transformation proposal for United Airlines by Cora and Process Street."
	image={`${base}/proposal/united-airlines-v2-hero.jpg`}
	noindex={true}
>

<Navbar />

<main>

	<!-- ===== HERO V2B: SPLIT LAYOUT ===== -->
	<section class="proposal-hero">
		<div class="proposal-hero-text">
			<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Proposal</span></div>
			<h1 class="proposal-hero-heading">Proposal for United Airlines</h1>
			<p class="proposal-hero-meta">Prepared by Cora &middot; March 7, 2026</p>
			<p class="proposal-hero-meta">Account Lead: Vinay Patankar &middot; vinay@cora.st</p>
			<p class="proposal-hero-valid">Valid through April 6, 2026</p>
		</div>
		<div class="proposal-hero-image">
			<img src={`${base}/proposal/united-airlines-v2-hero.jpg`} alt="Cora and United Airlines — geometric illustration of airport terminal with United aircraft" class="proposal-hero-img" width="1440" height="810" />
		</div>
	</section>

	<!-- ===== PERSONAL LETTER ===== -->
	<section class="section" style="padding-top: 4rem; padding-bottom: 3rem;">
		<div class="container" style="max-width: 720px;">
			<p style="font-size: 1.125rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				Dear United Airlines,
			</p>
			<p style="font-size: 1.125rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				United Airlines operates one of the most complex operational environments in the world. Hundreds of thousands of employees, thousands of daily flights, and a customer base that expects precision at every touchpoint. At that scale, even small inefficiencies in back-office operations compound into meaningful cost.
			</p>
			<p style="font-size: 1.125rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				We built Cora for exactly this kind of environment. Not to replace your people, but to give them leverage. A managed AI teammate that handles repetitive, high-volume operational work so your team can focus on judgment, strategy, and the customer experience that defines United's brand.
			</p>
			<p style="font-size: 1.125rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 2rem;">
				Every workflow we deploy for customers, we have already built and tested for ourselves. Let's get to work.
			</p>
			<p style="font-size: 1.125rem; color: var(--v2-text); font-weight: 500;">Vinay Patankar | Cofounder and CEO</p>
			<img src={`${base}/proposal/vinay-signature.png`} alt="Vinay Patankar signature" width="180" style="margin-top: 0.5rem; opacity: 0.85;" />
		</div>
	</section>

	<!-- ===== EXECUTIVE SUMMARY ===== -->
	<section class="section" style="padding-top: 2rem;">
		<div class="container" style="max-width: 720px;">
			<h2 class="section-title" style="text-align: left; font-size: 2rem; margin-bottom: 1.5rem;">Executive Summary</h2>
			<p style="font-size: 1.0625rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				United Airlines manages enormous operational complexity across 100,000+ employees, 4,800+ daily flights, and hundreds of airports. Back-office operations, compliance workflows, and internal communications still rely heavily on manual coordination. That manual overhead scales linearly with headcount. AI-powered operations do not.
			</p>
			<p style="font-size: 1.0625rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.5rem;">
				Cora becomes the operational leverage layer that lets United's teams do more without adding more people:
			</p>
			<ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1rem;">
				<li style="font-size: 1rem; color: var(--v2-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.6;"><span style="position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--v2-accent-softer); display: block;"></span>Automated compliance monitoring and audit preparation across FAA, DOT, and internal standards</li>
				<li style="font-size: 1rem; color: var(--v2-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.6;"><span style="position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--v2-accent-softer); display: block;"></span>AI-powered employee onboarding and offboarding at scale across all hubs</li>
				<li style="font-size: 1rem; color: var(--v2-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.6;"><span style="position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--v2-accent-softer); display: block;"></span>Intelligent customer communication triage and response drafting</li>
				<li style="font-size: 1rem; color: var(--v2-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.6;"><span style="position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--v2-accent-softer); display: block;"></span>Operational reporting and anomaly detection without manual data assembly</li>
			</ul>
		</div>
	</section>

	<!-- ===== CHALLENGES ===== -->
	<section class="section" style="padding-top: 2rem;">
		<div class="container">
			<h2 class="section-title" style="margin-bottom: 0.75rem;">Current Challenges</h2>
			<p class="section-desc" style="margin-bottom: 3rem;">Where manual coordination creates drag at United's scale.</p>
			<div class="features-grid">
				<div class="feature-card">
					<h3 class="feature-card-title" style="color: var(--v2-accent);">Manual Coordination at Scale</h3>
					<p class="feature-card-desc">8 major hubs, hundreds of stations, and cross-departmental handoffs for every HR lifecycle event, shift change, and rebooking workflow. Thousands of manual touchpoints daily across fragmented systems.</p>
				</div>
				<div class="feature-card">
					<h3 class="feature-card-title" style="color: var(--v2-accent);">Compliance and Regulatory Pressure</h3>
					<p class="feature-card-desc">FAA, DOT, TSA, and internal safety standards demand continuous audit preparation, training compliance tracking across 100,000+ employees, and consistent safety incident documentation.</p>
				</div>
				<div class="feature-card">
					<h3 class="feature-card-title" style="color: var(--v2-accent);">Customer Communication Volume</h3>
					<p class="feature-card-desc">Millions of annual interactions across call centers, email, social media, and airport counters. Routine inquiries follow predictable patterns but consume manual capacity that could serve higher-value work.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== WORKSPACE IMAGE BREAK ===== -->
	<section style="padding: 3rem 0;">
		<div class="container" style="max-width: 960px;">
			<img src={`${base}/proposal/united-airlines-v2-workspace.jpg`} alt="Cora workspace — Mac Mini with workflow dashboards and United Airlines aircraft" width="1200" height="630" style="border-radius: var(--v2-radius); box-shadow: var(--v2-shadow-lg); width: 100%; height: auto;" />
		</div>
	</section>

	<!-- ===== SOLUTION ===== -->
	<section class="section" style="padding-top: 2rem;">
		<div class="container" style="max-width: 720px;">
			<h2 class="section-title" style="text-align: left; font-size: 2rem; margin-bottom: 1.5rem;">The Solution</h2>
			<p style="font-size: 1.0625rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.5rem;">
				We propose a phased engagement beginning with a Managed AI Employee pilot in one operational function, with a clear path to an AI Transformation Program across United's operations.
			</p>

			<h3 style="font-size: 1.25rem; color: var(--v2-text); margin-bottom: 0.75rem; margin-top: 2rem;">Managed AI Employee (Pilot Phase)</h3>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				A dedicated AI teammate deployed on United's infrastructure, managed by our team, trained on your specific workflows. The agent operates continuously, connects to your existing tools, and executes real workflow tasks with human review and governance.
			</p>

			<h3 style="font-size: 1.25rem; color: var(--v2-text); margin-bottom: 0.75rem; margin-top: 2rem;">AI Transformation Program (Scale Phase)</h3>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8;">
				After proving value in the pilot, expand to a custom transformation program. We build a business brain (shared institutional memory), second brains for key leaders, and an operating model designed around agent orchestration rather than manual app-by-app work.
			</p>
		</div>
	</section>

	<!-- ===== WHY CORA ===== -->
	<section class="section roles">
		<div class="container">
			<h2 class="section-title" style="margin-bottom: 0.75rem;">Why Cora</h2>
			<p class="section-desc" style="margin-bottom: 3rem;">Six reasons this is fundamentally different.</p>
			<div class="roles-grid">
				<div class="role-card">
					<h3 class="role-card-title">Real Computer, Real Work</h3>
					<p class="role-card-desc">Cora operates on an actual computer using the same software your team uses. It opens Workday, navigates SAP, queries databases, and builds reports. A teammate that works the way your people work.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Managed, Not DIY</h3>
					<p class="role-card-desc">You do not need to build an AI team. We deploy, secure, maintain, and continuously optimize the agent. You get the output without the infrastructure overhead.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Security by Design</h3>
					<p class="role-card-desc">Aviation demands the highest standards. Tightest possible access from day one, daily automated audits, prompt injection defense, complete audit trails, and least-privilege architecture.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Built by Operators</h3>
					<p class="role-card-desc">Every workflow we deploy for customers, we have already built and tested internally. We are an operations company that ships working systems, not a consulting firm that recommends.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Continuous Improvement</h3>
					<p class="role-card-desc">The agent identifies inefficiencies, suggests optimizations, and builds new solutions autonomously. Every night, it gets better at your specific operations.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Cross-Domain Intelligence</h3>
					<p class="role-card-desc">One Cora agent covers what would require specialists across compliance, data operations, communications, reporting, and administration. Expert-level capability, available 24/7.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== BUSINESS CASE ===== -->
	<section class="section" style="padding-top: 2rem; padding-bottom: 3rem;">
		<div class="container" style="max-width: 860px;">
			<h2 class="section-title" style="margin-bottom: 0.75rem;">Business Case</h2>
			<p class="section-desc" style="margin-bottom: 2.5rem;">Consider just one function: employee lifecycle management across 100,000+ people and hundreds of locations.</p>

			<div style="overflow-x: auto;">
				<table style="width: 100%; border-collapse: separate; border-spacing: 0; border-radius: var(--v2-radius); overflow: hidden; border: 1px solid var(--v2-border); font-size: 0.9375rem;">
					<thead>
						<tr style="background: rgba(212, 98, 43, 0.06);">
							<th style="padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: var(--v2-text); border-bottom: 1px solid var(--v2-border);">Approach</th>
							<th style="padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: var(--v2-text); border-bottom: 1px solid var(--v2-border);">Annual Cost</th>
							<th style="padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: var(--v2-text); border-bottom: 1px solid var(--v2-border);">Coverage</th>
							<th style="padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: var(--v2-text); border-bottom: 1px solid var(--v2-border);">Availability</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Additional operations staff (3 FTEs)</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">$300,000+</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">One task at a time</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Business hours</td>
						</tr>
						<tr>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Consulting engagement</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">$500,000+</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Strategy, limited execution</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Project-based</td>
						</tr>
						<tr style="background: rgba(212, 98, 43, 0.06);">
							<td style="padding: 1rem 1.25rem; color: var(--v2-accent); font-weight: 600;">Cora Managed AI Employee</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-accent); font-weight: 600;">$36,000/year</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-accent); font-weight: 600;">Parallel execution</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-accent); font-weight: 600;">24/7/365</td>
						</tr>
					</tbody>
				</table>
			</div>

			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-top: 1.5rem; text-align: center; font-style: italic;">
				As operational complexity grows, manual coordination scales linearly. AI execution does not.
			</p>
		</div>
	</section>

	<!-- ===== ROLLOUT ===== -->
	<section class="section" style="background: var(--v2-text); color: #fff; padding: 4rem 0;">
		<div class="container">
			<h2 style="font-family: var(--v2-font-heading); font-size: 2.25rem; text-align: center; color: #fff; margin-bottom: 0.75rem;">Rollout Plan</h2>
			<p style="text-align: center; font-size: 1.0625rem; color: rgba(255,255,255,0.65); margin-bottom: 3rem;">From pilot to enterprise-scale transformation.</p>
			<div class="steps-grid" style="max-width: 960px; margin: 0 auto;">
				<div class="step-card">
					<div class="step-number">1</div>
					<h3 class="step-title">Pilot Deployment</h3>
					<p class="step-desc">Deploy a single Cora agent focused on compliance, HR lifecycle, or customer communication triage. Prove value in a contained scope. Weeks 1-4.</p>
				</div>
				<div class="step-card">
					<div class="step-number">2</div>
					<h3 class="step-title">Expansion</h3>
					<p class="step-desc">Iterate on Phase 1 workflows, add adjacent use cases, begin measuring ROI. Expand to a second operational function. Months 2-6.</p>
				</div>
				<div class="step-card">
					<div class="step-number">3</div>
					<h3 class="step-title">Transformation</h3>
					<p class="step-desc">Enterprise-scale rollout with business brain architecture, second brains for key leaders, and operating model redesign. Month 7+.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== INVESTMENT ===== -->
	<section class="section" style="padding-top: 4rem; padding-bottom: 2rem;">
		<div class="container" style="max-width: 720px;">
			<h2 class="section-title" style="text-align: left; font-size: 2rem; margin-bottom: 2rem;">Investment</h2>

			<div style="background: var(--v2-surface); border: 1px solid var(--v2-border); border-radius: var(--v2-radius); padding: 2rem; box-shadow: var(--v2-shadow); margin-bottom: 2rem;">
				<h3 style="font-size: 1.25rem; color: var(--v2-accent); margin-bottom: 1.5rem;">Managed AI Employee Pilot (Cora Flex)</h3>
				<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
					<div>
						<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Monthly Fee</p>
						<p style="font-size: 1.5rem; color: var(--v2-text); font-weight: 600;">$3,000/mo</p>
					</div>
					<div>
						<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Commitment</p>
						<p style="font-size: 1.5rem; color: var(--v2-text); font-weight: 600;">6 months</p>
					</div>
					<div>
						<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Workflow Hours</p>
						<p style="font-size: 1.5rem; color: var(--v2-text); font-weight: 600;">30 hrs/mo</p>
					</div>
					<div>
						<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Total Pilot</p>
						<p style="font-size: 1.5rem; color: var(--v2-accent); font-weight: 600;">$18,000</p>
					</div>
				</div>
				<div style="margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--v2-border);">
					<p style="font-size: 0.875rem; color: var(--v2-text-muted); line-height: 1.7;">Includes: implementation, maintenance, security monitoring, model optimization, hardware (Mac Mini or cloud instance). Additional workflow hours at $100/hr.</p>
				</div>
			</div>

			<p style="font-size: 0.9375rem; color: var(--v2-text-muted); line-height: 1.7; margin-bottom: 0.5rem;">
				Not included: AI model token costs ($50-$500/month, billed to your account), hardware costs if applicable (~$600-$800 Mac Mini), third-party tool subscriptions.
			</p>
			<p style="font-size: 0.9375rem; color: var(--v2-text-muted); line-height: 1.7;">
				AI Transformation Program (Phase 3+): custom scoped and priced based on pilot results.
			</p>
		</div>
	</section>

	<!-- ===== SECURITY ===== -->
	<section class="section" style="padding-top: 2rem; padding-bottom: 2rem;">
		<div class="container" style="max-width: 720px;">
			<h2 class="section-title" style="text-align: left; font-size: 2rem; margin-bottom: 1.5rem;">Security Approach</h2>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				We take a conservative, incremental approach designed to meet aviation-grade requirements. The agent starts within the tightest possible access boundaries. All external-facing actions require manual approval. Sensitive systems are accessed through bridge mechanisms, not direct integrations.
			</p>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				Access scope increases only after consistent accuracy: manual review of 100+ outputs with zero corrections before auto-send. Daily automated security audits, prompt injection guardrails, complete audit trail, and token spend limits are built in from day one.
			</p>
			<p style="font-size: 1rem; line-height: 1.8;">
				<a href={`${base}/security`} style="color: var(--v2-accent); text-decoration: none; font-weight: 500;">Learn more about our security framework &rarr;</a>
			</p>
		</div>
	</section>

	<!-- ===== TEAM + TERMS ===== -->
	<section class="section" style="padding-top: 2rem; padding-bottom: 2rem;">
		<div class="container" style="max-width: 720px;">
			<h2 class="section-title" style="text-align: left; font-size: 2rem; margin-bottom: 2rem;">Your Team</h2>

			<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 3rem;">
				<div style="background: var(--v2-surface); border: 1px solid var(--v2-border); border-radius: var(--v2-radius); padding: 1.5rem; text-align: center;">
					<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Account Lead</p>
					<p style="font-size: 1rem; color: var(--v2-text); font-weight: 600;">Vinay Patankar</p>
					<p style="font-size: 0.875rem; color: var(--v2-text-muted);">Strategy, escalation</p>
				</div>
				<div style="background: var(--v2-surface); border: 1px solid var(--v2-border); border-radius: var(--v2-radius); padding: 1.5rem; text-align: center;">
					<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Solutions Engineer</p>
					<p style="font-size: 1rem; color: var(--v2-text); font-weight: 600;">Lincoln</p>
					<p style="font-size: 0.875rem; color: var(--v2-text-muted);">Implementation, workflows</p>
				</div>
				<div style="background: var(--v2-surface); border: 1px solid var(--v2-border); border-radius: var(--v2-radius); padding: 1.5rem; text-align: center;">
					<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Customer Success</p>
					<p style="font-size: 1rem; color: var(--v2-text); font-weight: 600;">Gustavo Amaral</p>
					<p style="font-size: 0.875rem; color: var(--v2-text-muted);">Onboarding, training</p>
				</div>
			</div>

			<h2 class="section-title" style="text-align: left; font-size: 2rem; margin-bottom: 1.5rem;">Terms</h2>
			<div style="font-size: 0.9375rem; color: var(--v2-text-secondary); line-height: 1.8;">
				<p style="margin-bottom: 0.75rem;">6-month engagement from date of execution, renewing month-to-month thereafter. Either party may terminate with 30 days written notice after the initial term.</p>
				<p style="margin-bottom: 0.75rem;">Monthly invoicing, net 30 days. First month payable upon execution. 30 workflow hours per month, non-cumulative. Additional hours at $100/hour.</p>
				<p style="margin-bottom: 0.75rem;">Early termination requires payment of remaining months in the initial term.</p>
				<p>Both parties agree to maintain confidentiality of proprietary information. Mutual NDA executed alongside this agreement if not already in place.</p>
			</div>

			<div style="margin-top: 2rem; font-size: 0.875rem; color: var(--v2-text-muted);">
				<a href="https://www.process.st/terms" style="color: var(--v2-text-muted); text-decoration: underline;">Terms</a> &middot;
				<a href="https://www.process.st/privacy" style="color: var(--v2-text-muted); text-decoration: underline;">Privacy</a> &middot;
				<a href={`${base}/security`} style="color: var(--v2-text-muted); text-decoration: underline;">Security</a>
			</div>
		</div>
	</section>

	<!-- ===== ACCEPTANCE FORM ===== -->
	<section class="section" style="padding-top: 3rem; padding-bottom: 4rem;">
		<div class="container" style="max-width: 620px;">
			<div id="acceptance-card" style="background: var(--v2-surface); border: 2px solid var(--v2-accent); border-radius: var(--v2-radius); padding: 2.5rem; box-shadow: var(--v2-shadow-lg);">
				<!-- FORM STATE -->
				<div id="acceptance-form-wrap">
					<h2 style="font-family: var(--v2-font-heading); font-size: 1.75rem; text-align: center; color: var(--v2-text); margin-bottom: 0.5rem;">Accept this Proposal</h2>
					<p style="text-align: center; font-size: 0.9375rem; color: var(--v2-text-muted); margin-bottom: 2rem;">Your digital signature will be recorded and a signed PDF sent to both parties.</p>

					<form id="proposal-acceptance-form" style="display: flex; flex-direction: column; gap: 1rem;">
						<input type="hidden" name="proposal_slug" value="united-airlines-v2-2026-03-07" />
						<input type="hidden" name="client_name" value="United Airlines" />
						<input type="hidden" name="proposal_amount" value="$18,000" />
						<input type="hidden" name="offer_type" value="managed-ai-employee" />
						<input type="hidden" name="monthly_fee" value="$3,000" />
						<input type="hidden" name="commitment_term" value="6 months" />

						<div>
							<label style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--v2-text); margin-bottom: 0.35rem;">Full Name</label>
							<input type="text" name="signer_name" required placeholder="Your full name" maxlength="200" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--v2-border); border-radius: 8px; font-family: var(--v2-font); font-size: 1rem; background: #fff; color: var(--v2-text); outline: none;" />
						</div>
						<div>
							<label style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--v2-text); margin-bottom: 0.35rem;">Title</label>
							<input type="text" name="signer_title" required placeholder="Your role" maxlength="200" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--v2-border); border-radius: 8px; font-family: var(--v2-font); font-size: 1rem; background: #fff; color: var(--v2-text); outline: none;" />
						</div>
						<div>
							<label style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--v2-text); margin-bottom: 0.35rem;">Email</label>
							<input type="email" name="signer_email" required placeholder="you@united.com" maxlength="254" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--v2-border); border-radius: 8px; font-family: var(--v2-font); font-size: 1rem; background: #fff; color: var(--v2-text); outline: none;" />
						</div>
						<div>
							<label style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--v2-text); margin-bottom: 0.35rem;">Digital Signature</label>
							<input type="text" name="signer_signature" required placeholder="Type your full name as signature" maxlength="200" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--v2-border); border-radius: 8px; font-family: var(--v2-font); font-size: 1rem; font-style: italic; background: #fff; color: var(--v2-text); outline: none;" />
						</div>

						<button type="submit" id="accept-btn" class="btn btn-primary btn-lg" style="width: 100%; margin-top: 0.5rem;">Accept Proposal</button>

						<p style="font-size: 0.75rem; color: var(--v2-text-muted); text-align: center; line-height: 1.5; margin-top: 0.25rem;">
							By clicking Accept, you agree to the terms outlined in this proposal and authorize Process Street, Inc. to begin the Cora engagement.
						</p>
					</form>
				</div>

				<!-- LOADING STATE -->
				<div id="acceptance-loading" style="display: none; text-align: center; padding: 3rem 1rem;">
					<div style="display: inline-block; width: 40px; height: 40px; border: 3px solid var(--v2-border); border-top-color: var(--v2-accent); border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
					<p style="margin-top: 1.25rem; font-size: 1rem; color: var(--v2-text-muted);">Submitting your acceptance...</p>
				</div>

				<!-- SUCCESS STATE -->
				<div id="acceptance-success" style="display: none; text-align: center; padding: 3rem 1rem;">
					<div style="width: 56px; height: 56px; border-radius: 50%; background: var(--v2-accent); display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					</div>
