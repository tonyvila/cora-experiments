---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!--
Evergreen generic proposal template.
Copy this file into src/pages/proposal/[slug].astro and replace all placeholder tokens.
-->

<Layout
	title="Cora — Proposal for Nicole Osmer"
	description="AI transformation proposal template by Cora and Process Street."
	image={`${base}/proposal/nicole-osmer-2026-03-07-hero.jpg`}
	noindex={true}
>

<Navbar />

<main>

	<!-- ===== HERO V2C: BOTTOM FLOATING CARD ===== -->
	<section class="proposal-hero">
		<div class="proposal-hero-img-wrap">
				<img src={`${base}/proposal/nicole-osmer-2026-03-07-hero.jpg`} alt="Cora and Nicole Osmer — geometric illustration of operations transformation" class="proposal-hero-img" width="1440" height="810" />
		</div>
		<div class="proposal-hero-card-wrap container proposal-container-image">
			<div class="proposal-hero-card">
				<h1 class="proposal-hero-heading">Proposal for <span class="proposal-recipient">Nicole Osmer</span></h1>
					<p class="proposal-hero-meta">Prepared by Cora &middot; March 7, 2026</p>
				<p class="proposal-hero-meta">Account Lead: Vinay Patankar &middot; vinay@cora.st</p>
					<p class="proposal-hero-valid">Valid through April 6, 2026</p>
			</div>
		</div>
	</section>

	<!-- ===== PERSONAL LETTER ===== -->
	<section class="section proposal-letter-section">
		<div class="container proposal-container-narrow">
			<p style="font-size: 1.125rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				Dear Nicole Osmer,
			</p>
				<p style="font-size: 1.125rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">You have built deep credibility in healthcare and medtech communications, and now you are building the next phase of your operating model. The core challenge is not effort, it is leverage. High-value growth work is still constrained by manual research, list-building, and coordination across scattered systems.</p>
				<p style="font-size: 1.125rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">We built Cora for this exact transition. Not as another tool to manage, but as a managed AI transformation that builds your second brain, deploys practical agent workflows, and gives you a repeatable AI-first, agent-first operating rhythm.</p>
			<p style="font-size: 1.125rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 2rem;">
				Every workflow we deploy for customers, we have already built and tested for ourselves. Let's get to work.
			</p>
			<p style="font-size: 1.125rem; color: var(--v2-text); font-weight: 500;">Vinay Patankar | Cofounder and CEO</p>
			<img src={`${base}/proposal/vinay-signature.png`} alt="Vinay Patankar signature" width="180" style="margin-top: 0.5rem; opacity: 0.85;" />
		</div>
	</section>

	<!-- ===== EXECUTIVE SUMMARY ===== -->
	<section class="section proposal-tight-top">
		<div class="container proposal-container-narrow">
			<h2 class="section-title proposal-h2-left">Executive Summary</h2>
				<p style="font-size: 1.0625rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">Many high-performing operators still run critical growth workflows manually across documents, CRM, spreadsheets, and outreach tools. That creates a hard ceiling on output quality, speed, and consistency.</p>
				<p style="font-size: 1.0625rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.5rem;">This AI Transformation Program redesigns how your operating workflows run:</p>
			<ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1rem;">
					<li style="font-size: 1rem; color: var(--v2-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.6;"><span style="position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--v2-accent-softer); display: block;"></span>Second brain foundation capturing context, decisions, and operating memory</li>
					<li style="font-size: 1rem; color: var(--v2-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.6;"><span style="position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--v2-accent-softer); display: block;"></span>AI SDR workflow for repeatable research, targeting, and outreach draft support</li>
					<li style="font-size: 1rem; color: var(--v2-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.6;"><span style="position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--v2-accent-softer); display: block;"></span>Human-governed execution with review-first controls for all external-facing actions</li>
					<li style="font-size: 1rem; color: var(--v2-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.6;"><span style="position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--v2-accent-softer); display: block;"></span>Optional always-on second computer setup for background agent execution</li>
			</ul>
		</div>
	</section>

	<!-- ===== CHALLENGES ===== -->
	<section class="section proposal-tight-top">
		<div class="container">
			<h2 class="section-title" style="margin-bottom: 0.75rem;">Current Challenges</h2>
				<p class="section-desc" style="margin-bottom: 3rem;">Where manual coordination creates drag in your growth workflows.</p>
			<div class="features-grid">
				<div class="feature-card">
						<h3 class="feature-card-title" style="color: var(--v2-accent);">Manual Research Load</h3>
						<p class="feature-card-desc">High-value relationship and growth work still depends on manual prep. Research, targeting, and drafting consume operator time that should be used for strategic decision-making.</p>
				</div>
				<div class="feature-card">
						<h3 class="feature-card-title" style="color: var(--v2-accent);">Context Fragmentation</h3>
						<p class="feature-card-desc">Critical context lives across docs, spreadsheets, CRM entries, and inbox threads. This increases rework, slows execution, and makes consistent operating quality hard to sustain.</p>
				</div>
				<div class="feature-card">
						<h3 class="feature-card-title" style="color: var(--v2-accent);">Execution Bottlenecks</h3>
						<p class="feature-card-desc">Unstructured source material, including large directories and reports, is difficult to convert into actionable operating data quickly. This blocks downstream workflow automation and execution speed.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== WORKSPACE IMAGE BREAK ===== -->
	<section class="section proposal-image-break">
		<div class="container proposal-container-image">
			<img src={`${base}/proposal/nicole-osmer-2026-03-07-workspace.jpg`} alt="Cora workspace — geometric illustration of content operations infrastructure" width="1200" height="630" class="proposal-editorial-image" />
		</div>
	</section>

	<!-- ===== SOLUTION ===== -->
	<section class="section proposal-tight-top">
		<div class="container proposal-container-narrow">
			<h2 class="section-title proposal-h2-left">The Solution</h2>
				<p style="font-size: 1.0625rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.5rem;">We propose a 6-month AI Transformation Program for Nicole Osmer and Health+Commerce, focused on second brain foundation, AI SDR execution, and practical AI-first operating habits.</p>

			<h3 style="font-size: 1.25rem; color: var(--v2-text); margin-bottom: 0.75rem; margin-top: 2rem;">Business Brain Architecture</h3>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				A shared organizational context layer that captures institutional knowledge, processes, decision patterns, and operational history across departments. When a team member asks "how do we handle X," the answer exists in the system, not in someone's memory.
			</p>

			<h3 style="font-size: 1.25rem; color: var(--v2-text); margin-bottom: 0.75rem; margin-top: 2rem;">Second Brains for Key Leaders</h3>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				Each key leader gets a role-specific AI system that compounds their context and output quality over time. It remembers their preferences, understands their domain, and handles the operational work that consumes their strategic capacity.
			</p>

			<h3 style="font-size: 1.25rem; color: var(--v2-text); margin-bottom: 0.75rem; margin-top: 2rem;">Managed AI Agents</h3>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8;">
				Dedicated AI teammates deployed on real computers, managed by our team, trained on Nicole Osmer's specific workflows. Each agent operates continuously, connects to your existing tools (Workday, Jira, Slack, Google Workspace, Salesforce), and executes real workflow tasks with human review and governance.
			</p>
		</div>
	</section>

	<!-- ===== WHY CORA ===== -->
	<section class="section roles">
		<div class="container">
			<h2 class="section-title" style="margin-bottom: 0.75rem;">Why Cora</h2>
			<p class="section-desc" style="margin-bottom: 3rem;">Six reasons this is fundamentally different.</p>
			<div class="roles-grid">
				<div class="role-card">
					<h3 class="role-card-title">Real Computer, Real Work</h3>
					<p class="role-card-desc">Cora operates on an actual computer using the same software your team uses. It opens Workday, navigates Jira, queries Snowflake, and builds reports. A teammate that works the way your people work.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Managed, Not DIY</h3>
					<p class="role-card-desc">You do not need to build an AI operations team. We deploy, secure, maintain, and continuously optimize the agents. You get the output without the infrastructure overhead.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Security by Design</h3>
					<p class="role-card-desc">Tightest possible access from day one. Daily automated audits, prompt injection defense, complete audit trails, least-privilege architecture, and progressive autonomy earned through consistent accuracy.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Built by Operators</h3>
					<p class="role-card-desc">Every workflow we deploy for customers, we have already built and tested internally. We are an operations company that ships working systems, not a consulting firm that recommends.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Continuous Improvement</h3>
					<p class="role-card-desc">The agents identify inefficiencies, suggest optimizations, and build new solutions autonomously. Every night, they get better at your specific operations.</p>
				</div>
				<div class="role-card">
					<h3 class="role-card-title">Cross-Domain Intelligence</h3>
					<p class="role-card-desc">One Cora agent covers what would require specialists across compliance, data operations, communications, reporting, and administration. Expert-level capability across every domain, available 24/7.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== BUSINESS CASE ===== -->
	<section class="section proposal-tight-top proposal-tight-bottom">
		<div class="container proposal-container-wide">
			<h2 class="section-title" style="margin-bottom: 0.75rem;">Business Case</h2>
				<p class="section-desc" style="margin-bottom: 2.5rem;">Compare manual execution, ad hoc support, and a managed AI operating model.</p>

			<div style="overflow-x: auto;">
				<table style="width: 100%; border-collapse: separate; border-spacing: 0; border-radius: var(--v2-radius); overflow: hidden; border: 1px solid var(--v2-border); font-size: 0.9375rem;">
					<thead>
						<tr style="background: rgba(212, 98, 43, 0.06);">
							<th style="padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: var(--v2-text); border-bottom: 1px solid var(--v2-border);">Approach</th>
							<th style="padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: var(--v2-text); border-bottom: 1px solid var(--v2-border);">Annual Cost</th>
							<th style="padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: var(--v2-text); border-bottom: 1px solid var(--v2-border);">Scope</th>
							<th style="padding: 1rem 1.25rem; text-align: left; font-weight: 600; color: var(--v2-text); border-bottom: 1px solid var(--v2-border);">Outcome</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Internal AI ops team (4-5 FTEs)</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">$800K-$1.2M</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Single domain focus</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">12-18 month ramp</td>
						</tr>
						<tr>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Big 4 consulting engagement</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">$2M-$5M</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Strategy + roadmap</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-text-secondary); border-bottom: 1px solid var(--v2-border);">Slide deck, no execution</td>
						</tr>
						<tr style="background: rgba(212, 98, 43, 0.06);">
							<td style="padding: 1rem 1.25rem; color: var(--v2-accent); font-weight: 600;">Cora AI Transformation</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-accent); font-weight: 600;">$9,000</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-accent); font-weight: 600;">Cross-functional execution</td>
							<td style="padding: 1rem 1.25rem; color: var(--v2-accent); font-weight: 600;">Live agents in 30 days</td>
						</tr>
					</tbody>
				</table>
			</div>

			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-top: 1.5rem; text-align: center; font-style: italic;">
				As operational complexity grows, manual coordination scales linearly. AI execution does not.
			</p>
		</div>
	</section>

	<!-- ===== ROLLOUT ===== -->
	<section class="section proposal-rollout-section">
		<div class="container">
			<h2 class="proposal-rollout-heading">Rollout Plan</h2>
			<p class="proposal-rollout-sub">From first agent to enterprise-scale transformation.</p>
			<div class="steps-grid proposal-steps-grid">
				<div class="step-card">
					<div class="step-number">1</div>
					<h3 class="step-title">Month 1</h3>
					<p class="step-desc">Kickoff, data access boundary setup, first managed workflow deployed with review-first controls.</p>
				</div>
				<div class="step-card">
					<div class="step-number">2</div>
					<h3 class="step-title">Month 2</h3>
					<p class="step-desc">Business brain foundation live, core operating context and source systems structured for reliable retrieval.</p>
				</div>
				<div class="step-card">
					<div class="step-number">3</div>
					<h3 class="step-title">Month 3</h3>
					<p class="step-desc">First leader second brain deployed, output quality benchmarked, correction loop tuned for consistency.</p>
				</div>
				<div class="step-card">
					<div class="step-number">4</div>
					<h3 class="step-title">Month 4</h3>
					<p class="step-desc">Cross-functional agent workflows expanded with guardrails, approvals, and measurable SLA tracking.</p>
				</div>
				<div class="step-card">
					<div class="step-number">5</div>
					<h3 class="step-title">Month 5</h3>
					<p class="step-desc">Always-on execution patterns introduced for high-confidence recurring operations and background tasks.</p>
				</div>
				<div class="step-card">
					<div class="step-number">6</div>
					<h3 class="step-title">Month 6</h3>
					<p class="step-desc">Operating model handoff completed with governance cadence, roadmap, and expansion priorities defined.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== INVESTMENT ===== -->
	<section class="section proposal-investment-section">
		<div class="container proposal-container-narrow">
			<h2 class="section-title proposal-h2-left proposal-h2-spacious">Investment</h2>

				<div class="proposal-investment-card">
				<h3 style="font-size: 1.25rem; color: var(--v2-accent); margin-bottom: 1.5rem;">AI Transformation Program</h3>
				<div class="proposal-investment-grid">
					<div>
						<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Total Investment</p>
						<p style="font-size: 1.5rem; color: var(--v2-accent); font-weight: 600;">$9,000</p>
					</div>
					<div>
						<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Engagement Term</p>
						<p style="font-size: 1.5rem; color: var(--v2-text); font-weight: 600;">6 months</p>
					</div>
					<div>
						<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Solutions Engineering</p>
						<p style="font-size: 1.5rem; color: var(--v2-text); font-weight: 600;">15 hrs/mo</p>
					</div>
					<div>
						<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Monthly</p>
						<p style="font-size: 1.5rem; color: var(--v2-text); font-weight: 600;">$1,500/mo</p>
					</div>
				</div>
				<div style="margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--v2-border);">
					<p style="font-size: 0.875rem; color: var(--v2-text-muted); line-height: 1.7;">Includes: business brain architecture, second brains for key leaders, managed AI agents, implementation, ongoing maintenance, security monitoring, model optimization, dedicated solutions engineering. Additional hours at $100/hr.</p>
				</div>
			</div>

			<p style="font-size: 0.9375rem; color: var(--v2-text-muted); line-height: 1.7; margin-bottom: 0.5rem;">
				Not included: AI model token costs ($200-$2,000/month depending on workload, billed to your account), hardware costs if applicable, third-party tool subscriptions.
			</p>
		</div>
	</section>

	<!-- ===== SECURITY ===== -->
	<section class="section proposal-tight-top proposal-tight-bottom">
		<div class="container proposal-container-narrow">
			<h2 class="section-title proposal-h2-left">Security Approach</h2>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				We take a conservative, incremental approach designed for enterprise-grade requirements. Agents start within the tightest possible access boundaries. All external-facing actions require manual approval. Sensitive systems are accessed through bridge mechanisms, not direct integrations.
			</p>
			<p style="font-size: 1rem; color: var(--v2-text-secondary); line-height: 1.8; margin-bottom: 1.25rem;">
				Access scope increases only after consistent accuracy: manual review of 100+ outputs with zero corrections before auto-send. Daily automated security audits, prompt injection guardrails, complete audit trail, and token spend limits are built in from day one.
			</p>
			<p style="font-size: 1rem; line-height: 1.8;">
				<a href={`${base}/security`} style="color: var(--v2-accent); text-decoration: none; font-weight: 500;">Learn more about our security framework &rarr;</a>
			</p>
		</div>
	</section>

	<!-- ===== TEAM + TERMS ===== -->
	<section class="section proposal-tight-top proposal-tight-bottom">
		<div class="container proposal-container-narrow">
			<h2 class="section-title proposal-h2-left proposal-h2-spacious">Your Team</h2>

				<div class="proposal-team-grid">
					<div class="proposal-team-card">
					<img src={`${base}/proposal/nicole-osmer-2026-03-07-team-vinay.png`} alt="Vinay Patankar headshot" class="proposal-team-headshot" width="88" height="88" />
					<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Account Lead</p>
					<p style="font-size: 1rem; color: var(--v2-text); font-weight: 600;">Vinay Patankar</p>
					<p style="font-size: 0.875rem; color: var(--v2-text-muted);">Strategy, escalation</p>
				</div>
					<div class="proposal-team-card">
					<img src={`${base}/proposal/nicole-osmer-2026-03-07-team-lincoln.png`} alt="Lincoln Bauduin headshot" class="proposal-team-headshot" width="88" height="88" />
					<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Solutions Engineer</p>
					<p style="font-size: 1rem; color: var(--v2-text); font-weight: 600;">Lincoln Bauduin</p>
					<p style="font-size: 0.875rem; color: var(--v2-text-muted);">Implementation, workflows</p>
				</div>
					<div class="proposal-team-card">
					<img src={`${base}/proposal/nicole-osmer-2026-03-07-team-gustavo.png`} alt="Gustavo Amaral headshot" class="proposal-team-headshot" width="88" height="88" />
					<p style="font-size: 0.8125rem; color: var(--v2-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Customer Success</p>
					<p style="font-size: 1rem; color: var(--v2-text); font-weight: 600;">Gustavo Amaral</p>
					<p style="font-size: 0.875rem; color: var(--v2-text-muted);">Onboarding, training</p>
				</div>
			</div>

			<h2 class="section-title proposal-h2-left">Terms</h2>
			<div style="font-size: 0.9375rem; color: var(--v2-text-secondary); line-height: 1.8;">
				<p style="margin-bottom: 0.75rem;">Engagement term is defined in the Investment section above, renewing month-to-month thereafter. Either party may terminate with 30 days written notice after the initial term.</p>
				<p style="margin-bottom: 0.75rem;">Monthly invoicing, net 30 days. First month payable upon execution. Monthly solutions engineering scope is as listed in the Investment section. Additional hours at $100/hour.</p>
				<p style="margin-bottom: 0.75rem;">Early termination requires payment of remaining months in the initial term.</p>
				<p>Both parties agree to maintain confidentiality of proprietary information. Mutual NDA executed alongside this agreement if not already in place.</p>
			</div>

			<div style="margin-top: 2rem; font-size: 0.875rem; color: var(--v2-text-muted);">
				<a href="https://www.process.st/terms" style="color: var(--v2-text-muted); text-decoration: underline;">Terms</a> &middot;
				<a href="https://www.process.st/privacy" style="color: var(--v2-text-muted); text-decoration: underline;">Privacy</a> &middot;
				<a href={`${base}/security`} style="color: var(--v2-text-muted); text-decoration: underline;">Security</a>
			</div>
		</div>
	</section>

	<!-- ===== ACCEPTANCE FORM ===== -->
	<section class="section proposal-acceptance-section">
			<div class="container proposal-container-form">
				<div id="acceptance-card" class="proposal-acceptance-card">
				<!-- FORM STATE -->
				<div id="acceptance-form-wrap">
					<h2 style="font-family: var(--v2-font-heading); font-size: 1.75rem; text-align: center; color: var(--v2-text); margin-bottom: 0.5rem;">Accept this Proposal</h2>
					<p style="text-align: center; font-size: 0.9375rem; color: var(--v2-text-muted); margin-bottom: 2rem;">Your digital signature will be recorded and a signed PDF sent to both parties.</p>

						<form id="proposal-acceptance-form" class="proposal-acceptance-form">
						<input type="hidden" name="proposal_slug" value="nicole-osmer-2026-03-07" />
						<input type="hidden" name="client_name" value="Nicole Osmer" />
						<input type="hidden" name="proposal_amount" value="$9,000" />
						<input type="hidden" name="offer_type" value="ai-transformation-design-partner" />
						<input type="hidden" name="monthly_fee" value="$1,500" />
						<input type="hidden" name="commitment_term" value="6 months" />

						<div>
							<label style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--v2-text); margin-bottom: 0.35rem;">Full Name</label>
							<input type="text" name="signer_name" required placeholder="Your full name" maxlength="200" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--v2-border); border-radius: 8px; font-family: var(--v2-font); font-size: 1rem; background: #fff; color: var(--v2-text); outline: none;" />
						</div>
						<div>
							<label style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--v2-text); margin-bottom: 0.35rem;">Title</label>
							<input type="text" name="signer_title" required placeholder="Your role" maxlength="200" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--v2-border); border-radius: 8px; font-family: var(--v2-font); font-size: 1rem; background: #fff; color: var(--v2-text); outline: none;" />
						</div>
						<div>
							<label style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--v2-text); margin-bottom: 0.35rem;">Email</label>
							<input type="email" name="signer_email" required placeholder="you@example.com" maxlength="254" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--v2-border); border-radius: 8px; font-family: var(--v2-font); font-size: 1rem; background: #fff; color: var(--v2-text); outline: none;" />
						</div>
						<div>
							<label style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--v2-text); margin-bottom: 0.35rem;">Digital Signature</label>
							<input type="text" name="signer_signature" required placeholder="Type your full name as signature" maxlength="200" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--v2-border); border-radius: 8px; font-family: var(--v2-font); font-size: 1rem; font-style: italic; background: #fff; color: var(--v2-text); outline: none;" />
