---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faRobot, faComments, faClipboardList, faClock, faUserCheck, faGraduationCap, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconTools = icon(faRobot).html[0];
const iconOmnichannel = icon(faComments).html[0];
const iconKnowledge = icon(faClipboardList).html[0];
const iconInstant = icon(faClock).html[0];
const iconEscalation = icon(faUserCheck).html[0];
const iconLearning = icon(faGraduationCap).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Support Agent">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI-Powered Customer Support</span></div>
				<h1 class="hero-heading">Support That Actually Does Things. <span class="accent">Not Just Chat Responses.</span></h1>
				<p class="hero-sub">
					An AI support agent that logs into your tools, checks accounts, processes refunds, and resolves tickets. Not just another chatbot that says "let me transfer you to a human."
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">70%</span>
					<span class="hero-stat-label">Tickets resolved without human involvement</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">AI chatbots just deflect to humans</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Simple tickets take hours to resolve</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Support team can't cover nights/weekends</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Knowledge is siloed in people's heads</span></div>
				</div>

				<p class="problem-callout">What if your AI support agent could actually DO things: check accounts, process refunds, fix issues, not just respond with canned answers?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI SUPPORT AGENT DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Support Agent Does</h2>
				<p class="section-subtext">Real issue resolution, not just chat deflection, running on hardware you control with full access to your internal tools.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTools}></div>
						<h3 class="role-card-title">Actually Uses Your Tools</h3>
						<p class="role-card-desc">Not just chat responses. Your AI support agent logs into admin panels, checks account status, processes refunds, and executes real actions.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconOmnichannel}></div>
						<h3 class="role-card-title">Omnichannel Support</h3>
						<p class="role-card-desc">Email, chat, Slack, Discord: wherever your customers reach out, your AI support agent is there, with full context.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconKnowledge}></div>
						<h3 class="role-card-title">Deep Knowledge Base</h3>
						<p class="role-card-desc">Learns your product inside and out. Pulls from docs, past tickets, and internal resources to give accurate, helpful answers.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconInstant}></div>
						<h3 class="role-card-title">Instant Resolution</h3>
						<p class="role-card-desc">Resolves tickets in minutes, not hours. No waiting for human availability. Common issues handled automatically, 24/7.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconEscalation}></div>
						<h3 class="role-card-title">Smart Escalation</h3>
						<p class="role-card-desc">Knows when to hand off to humans. Complex issues, angry customers, or edge cases get routed to the right person with full context.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconLearning}></div>
						<h3 class="role-card-title">Continuous Learning</h3>
						<p class="role-card-desc">Gets smarter with every ticket. Learns from human resolutions, feedback, and new documentation automatically.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL SUPPORT OPERATIONS ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full Support Operations</h2>
				<p class="section-subtext">From first response to complete resolution, your AI handles tickets end-to-end.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Ticket Resolution</h3>
						<ul class="value-list">
							<li>Answer product questions accurately</li>
							<li>Troubleshoot common issues</li>
							<li>Provide step-by-step guidance</li>
							<li>Link to relevant documentation</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Account Actions</h3>
						<ul class="value-list">
							<li>Check account status and settings</li>
							<li>Process refunds and credits</li>
							<li>Update subscription plans</li>
							<li>Reset passwords and access</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Technical Support</h3>
						<ul class="value-list">
							<li>Debug integration issues</li>
							<li>Explain API errors</li>
							<li>Guide through configuration</li>
							<li>Reproduce and document bugs</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Escalation &amp; Handoff</h3>
						<ul class="value-list">
							<li>Identify complex edge cases</li>
							<li>Route to appropriate specialists</li>
							<li>Provide full conversation context</li>
							<li>Follow up after resolution</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== SUPPORT THAT SCALES ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Support That Scales</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">70%</span>
						<span class="stat-label">Tickets resolved without human involvement</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">&lt;2 min</span>
						<span class="stat-label">Average first response time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">4.8/5</span>
						<span class="stat-label">Customer satisfaction rating</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Support coverage, no extra shifts</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Systems</h3>
						<p class="step-desc">We connect to your help desk, admin tools, and knowledge base. Full access to resolve issues, not just respond.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Train on Your Product</h3>
						<p class="step-desc">Your AI Support Agent learns from your docs, past tickets, and internal processes. Becomes an expert on your product.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Start Resolving</h3>
						<p class="step-desc">Tickets start getting resolved in minutes. Complex issues get escalated with context. Your human team focuses on what matters.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready for Real AI Support?</h2>
				<p class="final-cta-sub">
					Tell us about your current ticket volume and biggest support challenges. We'll show you what autonomous resolution looks like.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
