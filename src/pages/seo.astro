---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faFileLines, faMagnifyingGlass, faChartLine, faRobot, faHandshake, faClipboardList, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconContent = icon(faFileLines).html[0];
const iconKeywords = icon(faMagnifyingGlass).html[0];
const iconRanking = icon(faChartLine).html[0];
const iconTechnical = icon(faRobot).html[0];
const iconLinks = icon(faHandshake).html[0];
const iconReporting = icon(faClipboardList).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI SEO Operator">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Built for Growing Businesses</span></div>
				<h1 class="hero-heading">SEO That Actually <span class="accent">Gets Done.</span></h1>
				<p class="hero-sub">
					Your AI SEO operator handles content creation, keyword research, technical fixes, and link building&mdash;the work of an entire SEO team at a fraction of the cost.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">156%</span>
					<span class="hero-stat-label">Average organic traffic increase</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Blog posts never get written</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Technical issues pile up unfixed</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No time for keyword research</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Competitors outranking you consistently</span></div>
				</div>

				<p class="problem-callout">What if content published on schedule, technical SEO stayed clean, and rankings climbed automatically?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI SEO OPERATOR DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI SEO Operator Does</h2>
				<p class="section-subtext">Complete SEO execution&mdash;content, technical, off-page&mdash;running 24/7.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconContent}></div>
						<h3 class="role-card-title">Content Creation</h3>
						<p class="role-card-desc">Writes SEO-optimized blog posts, landing pages, and product descriptions. Researches topics and keywords automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconKeywords}></div>
						<h3 class="role-card-title">Keyword Research</h3>
						<p class="role-card-desc">Identifies high-value keywords, analyzes search intent, and tracks ranking opportunities across your niche.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRanking}></div>
						<h3 class="role-card-title">Rank Tracking</h3>
						<p class="role-card-desc">Monitors your rankings daily. Alerts on significant changes. Tracks competitors' movement.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTechnical}></div>
						<h3 class="role-card-title">Technical SEO</h3>
						<p class="role-card-desc">Audits site health, fixes meta tags, optimizes page speed, and maintains technical SEO hygiene.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconLinks}></div>
						<h3 class="role-card-title">Link Building</h3>
						<p class="role-card-desc">Identifies link opportunities, conducts outreach, and tracks backlink acquisition and quality.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReporting}></div>
						<h3 class="role-card-title">Performance Reporting</h3>
						<p class="role-card-desc">Tracks organic traffic, conversions, and ROI. Generates weekly reports with actionable insights.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL-STACK SEO COVERAGE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full-Stack SEO Coverage</h2>
				<p class="section-subtext">From keyword research to link building, your AI handles the entire SEO workflow.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Content Strategy</h3>
						<ul class="value-list">
							<li>Topic cluster planning</li>
							<li>Content calendar management</li>
							<li>Competitive content analysis</li>
							<li>Content optimization recommendations</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">On-Page SEO</h3>
						<ul class="value-list">
							<li>Title and meta optimization</li>
							<li>Header structure optimization</li>
							<li>Internal linking strategy</li>
							<li>Schema markup implementation</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Off-Page SEO</h3>
						<ul class="value-list">
							<li>Backlink opportunity identification</li>
							<li>Outreach campaign management</li>
							<li>Guest post coordination</li>
							<li>Brand mention monitoring</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Technical SEO</h3>
						<ul class="value-list">
							<li>Site health monitoring</li>
							<li>Core Web Vitals optimization</li>
							<li>Crawl error resolution</li>
							<li>Sitemap and robots.txt management</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== RANKINGS THAT COMPOUND ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Rankings That Compound</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">156%</span>
						<span class="stat-label">Average organic traffic increase</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">47</span>
						<span class="stat-label">New keywords ranked monthly</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">12</span>
						<span class="stat-label">Blog posts published monthly</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Ranking monitoring</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Site</h3>
						<p class="step-desc">We integrate with Google Search Console, Analytics, and your CMS. Full visibility into your SEO performance.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Define Your Strategy</h3>
						<p class="step-desc">Share your target keywords, competitors, and goals. Your AI creates a content and optimization roadmap.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Watch Rankings Climb</h3>
						<p class="step-desc">Within weeks, content publishes, technical issues resolve, and organic traffic grows.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Stop Letting SEO Slip</h2>
				<p class="final-cta-sub">
					Get consistent execution on the SEO work that actually moves the needle.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
