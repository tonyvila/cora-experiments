---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faClipboardCheck, faShieldHalved, faUserCheck, faScaleBalanced, faEye, faFileLines, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconPreApproved = icon(faClipboardCheck).html[0];
const iconBoundaries = icon(faShieldHalved).html[0];
const iconApproval = icon(faUserCheck).html[0];
const iconPolicy = icon(faScaleBalanced).html[0];
const iconMonitoring = icon(faEye).html[0];
const iconReports = icon(faFileLines).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — Compliance Wrapper">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Enterprise Feature</span></div>
				<h1 class="hero-heading">AI That Stays <span class="accent">Within Boundaries.</span></h1>
				<p class="hero-sub">
					Compliance wrapper technology ensures your AI employee operates within your defined policies, regulations, and risk tolerance&mdash;automatically enforced.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">Zero</span>
					<span class="hero-stat-label">Unauthorized actions with policy enforcement</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">AI systems with no guardrails</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Compliance teams nervous about AI</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No way to enforce policies on AI actions</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Risk of AI doing something unauthorized</span></div>
				</div>

				<p class="problem-callout">What if your AI couldn't take actions outside your approved boundaries&mdash;with automatic enforcement and alerting?</p>
			</div>
		</section>

		<!-- ===== GUARDRAILS YOU CAN TRUST ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">Guardrails You Can Trust</h2>
				<p class="section-subtext">Define the boundaries. Your AI operates within them. Period.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconPreApproved}></div>
						<h3 class="role-card-title">Pre-Approved Actions</h3>
						<p class="role-card-desc">Define exactly what your AI can and cannot do. Actions outside the approved list are blocked automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconBoundaries}></div>
						<h3 class="role-card-title">Data Boundaries</h3>
						<p class="role-card-desc">Restrict what data your AI can access and where it can send information. Enforce data residency requirements.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconApproval}></div>
						<h3 class="role-card-title">Approval Workflows</h3>
						<p class="role-card-desc">Require human approval for sensitive actions. Multi-level approval chains for high-risk operations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconPolicy}></div>
						<h3 class="role-card-title">Policy Enforcement</h3>
						<p class="role-card-desc">Encode your compliance policies as rules. Your AI operates within your guardrails automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconMonitoring}></div>
						<h3 class="role-card-title">Real-Time Monitoring</h3>
						<p class="role-card-desc">See compliance status in real-time. Get alerts when actions approach or violate boundaries.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReports}></div>
						<h3 class="role-card-title">Audit Reports</h3>
						<p class="role-card-desc">Generate compliance reports on demand. Demonstrate adherence to regulatory requirements.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== COMPREHENSIVE POLICY ENFORCEMENT ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Comprehensive Policy Enforcement</h2>
				<p class="section-subtext">From access controls to approval workflows, every aspect is configurable and enforced.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Access Controls</h3>
						<ul class="value-list">
							<li>System and data access restrictions</li>
							<li>Time-based access windows</li>
							<li>Geographic restrictions</li>
							<li>Network boundary enforcement</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Action Policies</h3>
						<ul class="value-list">
							<li>Allowlist/denylist for actions</li>
							<li>Spending and transaction limits</li>
							<li>Communication restrictions</li>
							<li>Escalation requirements</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Approval Workflows</h3>
						<ul class="value-list">
							<li>Human-in-the-loop for sensitive actions</li>
							<li>Multi-level approval chains</li>
							<li>Time-limited approvals</li>
							<li>Emergency override procedures</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Compliance Frameworks</h3>
						<ul class="value-list">
							<li>Security controls mapping</li>
							<li>Healthcare safeguard enforcement</li>
							<li>GDPR data handling rules</li>
							<li>Industry-specific regulations</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== COMPLIANCE BY DESIGN ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Compliance By Design</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">100%</span>
						<span class="stat-label">Policy enforcement rate</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Zero</span>
						<span class="stat-label">Unauthorized actions</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Real-time</span>
						<span class="stat-label">Compliance monitoring</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Audit-ready</span>
						<span class="stat-label">Documentation always</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Define Your Policies</h3>
						<p class="step-desc">We work with you to encode your compliance requirements, access controls, and approval workflows.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Boundaries</h3>
						<p class="step-desc">Set up data boundaries, action restrictions, and monitoring rules. Your AI operates within your guardrails.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Deploy with Confidence</h3>
						<p class="step-desc">Your AI employee operates within defined boundaries. Violations are blocked, logged, and alerted.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">AI Your Compliance Team Will Love</h2>
				<p class="final-cta-sub">
					Deploy AI with automatic policy enforcement, real-time monitoring, and audit-ready documentation.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
