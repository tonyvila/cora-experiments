---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faClock, faMoneyCheckDollar, faUserCheck, faRocket, faChartLine, faShieldHalved, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconTimezone = icon(faClock).html[0];
const iconPricing = icon(faMoneyCheckDollar).html[0];
const iconTurnover = icon(faUserCheck).html[0];
const iconScaling = icon(faRocket).html[0];
const iconVisibility = icon(faChartLine).html[0];
const iconSecurity = icon(faShieldHalved).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Back Office Outsourcing">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI Back Office Outsourcing</span></div>
				<h1 class="hero-heading">Outsource to AI. <span class="accent">Not to Another Country.</span></h1>
				<p class="hero-sub">
					Replace offshore BPO with AI employees. Same cost savings, zero turnover, no time zone headaches, and your data never leaves the US.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">70%</span>
					<span class="hero-stat-label">Cost savings vs. traditional BPO</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Offshore outsourcing means time zone coordination hell</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">BPO turnover forces constant retraining</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Quality varies wildly month to month</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Data security concerns keep legal up at night</span></div>
				</div>

				<p class="problem-callout">What if you could outsource back office work to workers who never quit, never sleep, and keep your data secure on US soil?</p>
			</div>
		</section>

		<!-- ===== THE BETTER WAY TO OUTSOURCE ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">The Better Way to Outsource</h2>
				<p class="section-subtext">All the benefits of outsourcing, none of the headaches.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTimezone}></div>
						<h3 class="role-card-title">Same Time Zone, Better Execution</h3>
						<p class="role-card-desc">AI employees work US hours without offshore coordination headaches. No language barriers, no cultural mismatches.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconPricing}></div>
						<h3 class="role-card-title">Predictable Pricing</h3>
						<p class="role-card-desc">Flat monthly fees. No hidden charges, no scope creep, no surprise invoices. Know exactly what you'll pay.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTurnover}></div>
						<h3 class="role-card-title">Zero Turnover</h3>
						<p class="role-card-desc">AI employees don't quit, don't get poached, and don't need to be rehired. Consistent quality forever.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconScaling}></div>
						<h3 class="role-card-title">Instant Scaling</h3>
						<p class="role-card-desc">Add capacity in days, not months. No recruiting, no training, no ramp time. Just results.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconVisibility}></div>
						<h3 class="role-card-title">Full Visibility</h3>
						<p class="role-card-desc">Real-time dashboards show exactly what's being done. Complete audit trails and performance metrics.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconSecurity}></div>
						<h3 class="role-card-title">Data Security</h3>
						<p class="role-card-desc">Your data stays in the US on secure infrastructure. security-focused, fully auditable, zero offshore risk.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FUNCTIONS WE HANDLE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Functions We Handle</h2>
				<p class="section-subtext">Every repetitive back office function, handled by AI employees.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Finance &amp; Accounting</h3>
						<ul class="value-list">
							<li>Accounts payable processing</li>
							<li>Accounts receivable management</li>
							<li>Bank reconciliation</li>
							<li>Financial reporting</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Customer Operations</h3>
						<ul class="value-list">
							<li>Tier 1 support ticket handling</li>
							<li>Order processing</li>
							<li>Returns and refund management</li>
							<li>Customer data maintenance</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Administrative</h3>
						<ul class="value-list">
							<li>Data entry and validation</li>
							<li>Document processing</li>
							<li>Schedule coordination</li>
							<li>Travel booking</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Sales Operations</h3>
						<ul class="value-list">
							<li>CRM data hygiene</li>
							<li>Lead enrichment</li>
							<li>Quote generation</li>
							<li>Contract administration</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">70%</span>
						<span class="stat-label">Cost savings vs. traditional BPO</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">0%</span>
						<span class="stat-label">Turnover and retraining</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">99.9%</span>
						<span class="stat-label">Process accuracy</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Operations without night shift</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Define Your Processes</h3>
						<p class="step-desc">We map your current back office processes and identify what AI employees can handle immediately.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Deploy &amp; Integrate</h3>
						<p class="step-desc">AI employees connect to your systems and start handling work. Full training on your specific processes.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Monitor &amp; Optimize</h3>
						<p class="step-desc">Real-time dashboards show performance. Continuous improvement based on your feedback and results.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Reimagine Outsourcing?</h2>
				<p class="final-cta-sub">
					Tell us about your current back office operations. We'll show you exactly how much you can save with AI outsourcing.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
