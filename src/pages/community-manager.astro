---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faComments, faShieldHalved, faUserCheck, faChartLine, faCalendarDays, faUsers, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconResponse = icon(faComments).html[0];
const iconModeration = icon(faShieldHalved).html[0];
const iconOnboarding = icon(faUserCheck).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconEvents = icon(faCalendarDays).html[0];
const iconRecognition = icon(faUsers).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Community Manager">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI-Powered Community</span></div>
				<h1 class="hero-heading">Your Community Deserves Better <span class="accent">Than Unanswered Questions.</span></h1>
				<p class="hero-sub">
					An AI community manager that responds to every question, moderates 24/7, and makes your members feel heard, across Slack, Discord, and forums.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">2min</span>
					<span class="hero-stat-label">Average response time, any time zone</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Questions sit unanswered while you sleep</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Spam and trolls slip through moderation</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Top contributors burn out and leave</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">You can't scale community without scaling team</span></div>
				</div>

				<p class="problem-callout">What if every member got a response within minutes, and your community ran itself while you focused on strategy?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI COMMUNITY MANAGER DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Community Manager Does</h2>
				<p class="section-subtext">Everything a great community manager does: respond, moderate, engage, running autonomously around the clock.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconResponse}></div>
						<h3 class="role-card-title">24/7 Question Response</h3>
						<p class="role-card-desc">Answers member questions in Slack, Discord, or forums instantly. Never lets a question sit unanswered overnight.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconModeration}></div>
						<h3 class="role-card-title">Moderation &amp; Safety</h3>
						<p class="role-card-desc">Removes spam, enforces rules, and handles toxic behavior automatically. Keeps your community clean and welcoming.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconOnboarding}></div>
						<h3 class="role-card-title">Onboarding Automation</h3>
						<p class="role-card-desc">Greets new members, walks them through community guidelines, and connects them with relevant channels and resources.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Engagement Analytics</h3>
						<p class="role-card-desc">Tracks active members, conversation trends, and sentiment. Identifies at-risk members before they churn.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconEvents}></div>
						<h3 class="role-card-title">Event Coordination</h3>
						<p class="role-card-desc">Schedules AMAs, announces events, sends reminders, and manages RSVPs. Keeps community programming running.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRecognition}></div>
						<h3 class="role-card-title">Member Recognition</h3>
						<p class="role-card-desc">Identifies top contributors, awards badges, and highlights valuable discussions. Builds culture automatically.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL-STACK COMMUNITY OPERATIONS ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full-Stack Community Operations</h2>
				<p class="section-subtext">From question response to member recognition, your AI handles the entire community workflow.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Slack Management</h3>
						<ul class="value-list">
							<li>Triage and route questions to the right channels</li>
							<li>Auto-archive stale threads</li>
							<li>Surface unanswered questions for human review</li>
							<li>Summarize long threads and decisions</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Discord Operations</h3>
						<ul class="value-list">
							<li>Role management and verification</li>
							<li>Auto-moderation with configurable rules</li>
							<li>Welcome flows and onboarding sequences</li>
							<li>Voice channel management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Forum &amp; Circle Management</h3>
						<ul class="value-list">
							<li>Respond to posts within minutes</li>
							<li>Tag and categorize content automatically</li>
							<li>Highlight trending discussions</li>
							<li>Identify and escalate product feedback</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Community Intelligence</h3>
						<ul class="value-list">
							<li>Member health scoring and churn prediction</li>
							<li>Sentiment analysis across conversations</li>
							<li>Topic trend identification</li>
							<li>NPS and satisfaction tracking</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">2min</span>
						<span class="stat-label">Average response time to questions</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">95%</span>
						<span class="stat-label">Questions resolved without human help</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">40%</span>
						<span class="stat-label">Increase in member engagement</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Community never goes quiet</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Platforms</h3>
						<p class="step-desc">Link your Slack, Discord, Circle, or forum. Define your community guidelines and tone of voice.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Train on Your Knowledge</h3>
						<p class="step-desc">We ingest your docs, FAQs, and past conversations. Your AI learns how your community operates.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Launch &amp; Scale</h3>
						<p class="step-desc">Your AI community manager goes live. Questions get answered, spam gets removed, members feel heard.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Scale Your Community?</h2>
				<p class="final-cta-sub">
					Tell us about your community and current challenges. We'll show you exactly how an AI community manager fits.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
