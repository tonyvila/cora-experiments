---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faMagnifyingGlass, faPaperPlane, faFileLines, faCalendarDays, faComments, faChartLine, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconSourcing = icon(faMagnifyingGlass).html[0];
const iconOutreach = icon(faPaperPlane).html[0];
const iconScreening = icon(faFileLines).html[0];
const iconScheduling = icon(faCalendarDays).html[0];
const iconComms = icon(faComments).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Recruiting Assistant">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Built for Recruiting Teams</span></div>
				<h1 class="hero-heading">Fill Roles Faster <span class="accent">Without Burning Out.</span></h1>
				<p class="hero-sub">
					Your AI recruiting assistant handles sourcing, screening, scheduling, and candidate communication&mdash;freeing your team to focus on selling candidates and closing offers.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">50%</span>
					<span class="hero-stat-label">Average reduction in time-to-fill</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Sourcing eats hours every day</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Resumes pile up unreviewed</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Scheduling is endless back-and-forth</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Candidates get ghosted in the process</span></div>
				</div>

				<p class="problem-callout">What if candidates sourced themselves, screening happened instantly, and scheduling was automatic?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI RECRUITING ASSISTANT DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Recruiting Assistant Does</h2>
				<p class="section-subtext">Complete recruiting operations&mdash;sourcing, screening, scheduling, communication&mdash;automated 24/7.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconSourcing}></div>
						<h3 class="role-card-title">Candidate Sourcing</h3>
						<p class="role-card-desc">Searches LinkedIn, job boards, and databases to find qualified candidates. Builds targeted talent pipelines automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconOutreach}></div>
						<h3 class="role-card-title">Outreach Campaigns</h3>
						<p class="role-card-desc">Sends personalized outreach to passive candidates. Handles follow-ups and schedules conversations automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconScreening}></div>
						<h3 class="role-card-title">Resume Screening</h3>
						<p class="role-card-desc">Reviews applications against job requirements. Ranks candidates by fit. Surfaces the best candidates instantly.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconScheduling}></div>
						<h3 class="role-card-title">Interview Scheduling</h3>
						<p class="role-card-desc">Coordinates calendars, sends invites, and manages rescheduling. No more scheduling ping-pong.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconComms}></div>
						<h3 class="role-card-title">Candidate Communication</h3>
						<p class="role-card-desc">Keeps candidates informed at every stage. Answers questions, sends updates, and maintains engagement.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Pipeline Analytics</h3>
						<p class="role-card-desc">Tracks time-to-fill, source effectiveness, and conversion rates. Data-driven recruiting decisions.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL-CYCLE RECRUITING SUPPORT ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full-Cycle Recruiting Support</h2>
				<p class="section-subtext">From sourcing to offer, your AI handles the administrative heavy lifting.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Sourcing &amp; Outreach</h3>
						<ul class="value-list">
							<li>Multi-platform candidate search</li>
							<li>Personalized outreach campaigns</li>
							<li>Follow-up automation</li>
							<li>Talent pool development</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Screening &amp; Assessment</h3>
						<ul class="value-list">
							<li>AI resume screening</li>
							<li>Skill matching and ranking</li>
							<li>Pre-screening questions</li>
							<li>Assessment coordination</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Interview Management</h3>
						<ul class="value-list">
							<li>Automated scheduling</li>
							<li>Panel coordination</li>
							<li>Interview prep materials</li>
							<li>Feedback collection</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Candidate Experience</h3>
						<ul class="value-list">
							<li>Status updates and communication</li>
							<li>Question handling</li>
							<li>Offer letter generation</li>
							<li>Onboarding coordination</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HIRE FASTER, HIRE BETTER ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Hire Faster, Hire Better</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">50%</span>
						<span class="stat-label">Reduction in time-to-fill</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">3x</span>
						<span class="stat-label">More candidates sourced</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Zero</span>
						<span class="stat-label">Candidates ghosted</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Candidate responsiveness</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your ATS</h3>
						<p class="step-desc">We integrate with Greenhouse, Lever, Workable, and more. Your recruiting data stays in sync.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Define Your Roles</h3>
						<p class="step-desc">Share your job requirements, ideal candidate profiles, and hiring criteria. Your AI learns what you need.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Fill Your Pipeline</h3>
						<p class="step-desc">Within days, qualified candidates flow in. Scheduling handles itself. You focus on final decisions.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Stop Drowning in Recruiting Admin</h2>
				<p class="final-cta-sub">
					Let AI handle sourcing and scheduling while you focus on selling your company and closing great candidates.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
