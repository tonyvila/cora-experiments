---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faCalendarCheck, faCommentDots, faStar, faUsers, faBoxesStacked, faChartLine, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconReservations = icon(faCalendarCheck).html[0];
const iconGuest = icon(faCommentDots).html[0];
const iconReviews = icon(faStar).html[0];
const iconStaff = icon(faUsers).html[0];
const iconInventory = icon(faBoxesStacked).html[0];
const iconRevenue = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Employees for Hospitality">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI for Hospitality</span></div>
				<h1 class="hero-heading">Five-Star Service. <span class="accent">Without the Overhead.</span></h1>
				<p class="hero-sub">
					An AI employee for hotels and restaurants that handles reservations, guest communication, and operations 24/7&nbsp;&mdash; so your team can focus on creating memorable experiences.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">30%</span>
					<span class="hero-stat-label">Reduction in operational costs</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Phone lines ring while staff serve guests</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Reviews go unanswered and reputation suffers</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Scheduling is a constant headache</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Revenue optimization requires expensive consultants</span></div>
				</div>

				<p class="problem-callout">What if every reservation got handled instantly, every review got a thoughtful response, and your pricing adjusted automatically to maximize revenue?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI HOSPITALITY EMPLOYEE DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Hospitality Employee Does</h2>
				<p class="section-subtext">Everything that keeps your team from guests&nbsp;&mdash; reservations, reviews, operations&nbsp;&mdash; handled autonomously.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReservations}></div>
						<h3 class="role-card-title">Reservation Management</h3>
						<p class="role-card-desc">Handles booking requests 24/7 across phone, email, and web. Optimizes seating and room assignments automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconGuest}></div>
						<h3 class="role-card-title">Guest Communication</h3>
						<p class="role-card-desc">Sends confirmations, pre-arrival details, and follow-ups. Answers common questions without human intervention.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReviews}></div>
						<h3 class="role-card-title">Review Management</h3>
						<p class="role-card-desc">Monitors and responds to reviews across TripAdvisor, Yelp, and Google. Turns negative feedback into recovery opportunities.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconStaff}></div>
						<h3 class="role-card-title">Staff Scheduling</h3>
						<p class="role-card-desc">Optimizes schedules based on demand forecasts, handles shift swaps, and manages time-off requests.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconInventory}></div>
						<h3 class="role-card-title">Inventory &amp; Ordering</h3>
						<p class="role-card-desc">Tracks inventory levels, generates purchase orders, and manages vendor relationships automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRevenue}></div>
						<h3 class="role-card-title">Revenue Optimization</h3>
						<p class="role-card-desc">Adjusts pricing based on demand, competition, and events. Maximizes RevPAR and average check.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== BUILT FOR HOSPITALITY ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Built for Hospitality</h2>
				<p class="section-subtext">Deep understanding of hospitality operations, from boutique hotels to restaurant groups.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Hotels &amp; Resorts</h3>
						<ul class="value-list">
							<li>Direct booking optimization</li>
							<li>OTA parity management</li>
							<li>Housekeeping coordination</li>
							<li>Guest preference tracking</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Restaurants</h3>
						<ul class="value-list">
							<li>Reservation and waitlist management</li>
							<li>Table turn optimization</li>
							<li>Special event coordination</li>
							<li>Menu engineering insights</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Operations</h3>
						<ul class="value-list">
							<li>Demand forecasting</li>
							<li>Labor cost optimization</li>
							<li>Preventive maintenance scheduling</li>
							<li>Quality control checklists</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Guest Experience</h3>
						<ul class="value-list">
							<li>Pre-arrival personalization</li>
							<li>Real-time request handling</li>
							<li>Loyalty program management</li>
							<li>Post-stay engagement</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">30%</span>
						<span class="stat-label">Reduction in labor costs</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">15%</span>
						<span class="stat-label">Increase in direct bookings</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">4.5&#9733;</span>
						<span class="stat-label">Average review rating improvement</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Guest service availability</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Systems</h3>
						<p class="step-desc">Integrate with your PMS, POS, and booking channels. We work with all major hospitality platforms.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Your Operations</h3>
						<p class="step-desc">Define service standards, pricing rules, and communication templates. Your AI learns your brand voice.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Elevate Guest Experience</h3>
						<p class="step-desc">Reservations flow in, guests feel cared for, and your team focuses on memorable experiences.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Elevate Your Guest Experience?</h2>
				<p class="final-cta-sub">
					Tell us about your property and current challenges. We'll show you exactly how AI can improve service and reduce costs.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
