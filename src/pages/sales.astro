---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faMagnifyingGlass, faFileLines, faArrowRightArrowLeft, faClipboardList, faComments, faChartLine, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconProspecting = icon(faMagnifyingGlass).html[0];
const iconOutreach = icon(faFileLines).html[0];
const iconSequences = icon(faArrowRightArrowLeft).html[0];
const iconCRM = icon(faClipboardList).html[0];
const iconReply = icon(faComments).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI SDR">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI-Powered SDR</span></div>
				<h1 class="hero-heading">Stop Hiring SDRs. <span class="accent">Deploy One That Never Sleeps.</span></h1>
				<p class="hero-sub">
					An AI SDR that prospects, personalizes, and books meetings 24/7. Not a tool you configure, but an employee that runs your entire outbound motion end-to-end.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">3x</span>
					<span class="hero-stat-label">More meetings than human SDRs at 1/3 the cost</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">SDRs take 3-6 months to ramp up</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Good ones leave after 12-18 months</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Outreach quality drops as volume increases</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">CRM data is always a mess</span></div>
				</div>

				<p class="problem-callout">What if you could have an SDR that's fully ramped on day one, never quits, and actually keeps your CRM clean?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI SDR DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI SDR Does</h2>
				<p class="section-subtext">Everything a great SDR does: research, personalize, execute, follow up, running autonomously on dedicated hardware you control.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconProspecting}></div>
						<h3 class="role-card-title">Autonomous Prospecting</h3>
						<p class="role-card-desc">Finds and researches ideal prospects from LinkedIn, Apollo, ZoomInfo, and your ICP criteria. No manual list building.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconOutreach}></div>
						<h3 class="role-card-title">Hyper-Personalized Outreach</h3>
						<p class="role-card-desc">Writes emails that reference specific company news, tech stack, job postings, and pain points. Not templates. Real personalization.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconSequences}></div>
						<h3 class="role-card-title">Multi-Touch Sequences</h3>
						<p class="role-card-desc">Runs email, LinkedIn, and call sequences automatically. Adjusts timing and messaging based on engagement signals.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCRM}></div>
						<h3 class="role-card-title">CRM Hygiene</h3>
						<p class="role-card-desc">Updates Salesforce/HubSpot with every touchpoint. Creates contacts, logs activities, and moves deals through stages.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReply}></div>
						<h3 class="role-card-title">Reply Handling</h3>
						<p class="role-card-desc">Responds to positive replies, handles objections, and books meetings directly on your calendar. Escalates hot leads instantly.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Performance Analytics</h3>
						<p class="role-card-desc">Tracks open rates, reply rates, and conversion by message, sequence, and ICP segment. Optimizes automatically.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL-STACK OUTBOUND ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full-Stack Outbound</h2>
				<p class="section-subtext">From prospect identification to booked meeting, your AI SDR handles the entire workflow.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Prospecting &amp; Research</h3>
						<ul class="value-list">
							<li>Build targeted prospect lists from multiple data sources</li>
							<li>Enrich contacts with company data, tech stack, and signals</li>
							<li>Score and prioritize leads based on ICP fit</li>
							<li>Track job changes and trigger events</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Outbound Execution</h3>
						<ul class="value-list">
							<li>Send personalized cold emails at scale</li>
							<li>Execute LinkedIn connection and messaging sequences</li>
							<li>Coordinate multi-channel touchpoints</li>
							<li>A/B test messaging automatically</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Follow-Up &amp; Engagement</h3>
						<ul class="value-list">
							<li>Handle replies and book meetings</li>
							<li>Nurture cold leads over time</li>
							<li>Re-engage stale opportunities</li>
							<li>Escalate hot leads to human reps instantly</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">CRM &amp; Pipeline Management</h3>
						<ul class="value-list">
							<li>Create and update contacts automatically</li>
							<li>Log all activities and touchpoints</li>
							<li>Move deals through pipeline stages</li>
							<li>Generate pipeline reports and forecasts</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">500+</span>
						<span class="stat-label">Personalized emails sent per day</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">3x</span>
						<span class="stat-label">More meetings booked vs human SDR</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">80%</span>
						<span class="stat-label">Reduction in cost per meeting</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Outbound never stops</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Define Your ICP</h3>
						<p class="step-desc">We work with you to define your ideal customer profile, target accounts, and messaging strategy.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Connect Your Tools</h3>
						<p class="step-desc">Your AI SDR connects to your CRM, email, LinkedIn, and prospecting tools. Full access, full control.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Launch Outbound</h3>
						<p class="step-desc">Within days, personalized outreach starts flowing. Meetings appear on calendars. Pipeline grows.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Scale Outbound?</h2>
				<p class="final-cta-sub">
					Tell us about your ICP and current outbound motion. We'll show you exactly how an AI SDR fits.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
