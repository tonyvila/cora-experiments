---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faLayerGroup, faMoneyCheckDollar, faArrowsRotate, faCommentDots, faTruckFast, faChartLine } from '@fortawesome/pro-light-svg-icons';
const iconListing = icon(faLayerGroup).html[0];
const iconPricing = icon(faMoneyCheckDollar).html[0];
const iconSync = icon(faArrowsRotate).html[0];
const iconComms = icon(faCommentDots).html[0];
const iconOrders = icon(faTruckFast).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Employees for Marketplace Sellers">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Built for Resellers & Marketplace Sellers</span></div>
				<h1 class="hero-heading">Sell on Every Platform. <span class="accent">Without the Chaos.</span></h1>
				<p class="hero-sub">
					Your AI marketplace operator manages listings, pricing, inventory, and customer service across eBay, Poshmark, Mercari, and more&nbsp;&mdash; all from one place.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">40%</span>
					<span class="hero-stat-label">More listings across platforms</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Managing listings across platforms is a nightmare</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Inventory doesn't sync&mdash;oversells happen</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Messages pile up unanswered</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No time to optimize pricing or descriptions</span></div>
				</div>

				<p class="problem-callout">What if all your platforms synced perfectly, messages answered themselves, and pricing optimized automatically?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI MARKETPLACE OPERATOR DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Marketplace Operator Does</h2>
				<p class="section-subtext">Complete multi-platform selling operations&nbsp;&mdash; listings, inventory, orders, customer service&nbsp;&mdash; automated 24/7.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconListing}></div>
						<h3 class="role-card-title">Multi-Platform Listing</h3>
						<p class="role-card-desc">Manages listings across eBay, Poshmark, Mercari, Depop, and more. One product, everywhere, automatically synced.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconPricing}></div>
						<h3 class="role-card-title">Dynamic Pricing</h3>
						<p class="role-card-desc">Monitors competitor pricing and market demand. Adjusts your prices automatically to maximize sales and margins.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconSync}></div>
						<h3 class="role-card-title">Inventory Sync</h3>
						<p class="role-card-desc">Real-time inventory sync across all platforms. Prevents overselling. Updates quantity as items sell.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconComms}></div>
						<h3 class="role-card-title">Customer Communication</h3>
						<p class="role-card-desc">Responds to buyer questions across all platforms. Handles offers, negotiations, and post-sale follow-up.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconOrders}></div>
						<h3 class="role-card-title">Order Management</h3>
						<p class="role-card-desc">Processes orders, generates shipping labels, and updates tracking across all platforms automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Performance Analytics</h3>
						<p class="role-card-desc">Tracks sales, margins, and platform performance. Identifies best sellers and optimization opportunities.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== SELL EVERYWHERE, MANAGE ONCE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Sell Everywhere, Manage Once</h2>
				<p class="section-subtext">Native integration with all major marketplaces. Your AI keeps everything in sync.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Listing Management</h3>
						<ul class="value-list">
							<li>Multi-platform listing creation</li>
							<li>SEO-optimized titles and descriptions</li>
							<li>Photo enhancement and management</li>
							<li>Category and attribute optimization</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Pricing &amp; Inventory</h3>
						<ul class="value-list">
							<li>Competitive price monitoring</li>
							<li>Dynamic repricing rules</li>
							<li>Cross-platform inventory sync</li>
							<li>Low stock alerts</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Order Fulfillment</h3>
						<ul class="value-list">
							<li>Automated order processing</li>
							<li>Shipping label generation</li>
							<li>Tracking number updates</li>
							<li>Returns management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Customer Service</h3>
						<ul class="value-list">
							<li>Message response automation</li>
							<li>Offer handling and negotiation</li>
							<li>Review and feedback management</li>
							<li>Dispute resolution support</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== SCALE YOUR RESELLING BUSINESS ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Scale Your Reselling Business</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">40%</span>
						<span class="stat-label">More listings across platforms</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Zero</span>
						<span class="stat-label">Oversells from inventory sync</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">2hrs</span>
						<span class="stat-label">Response time to all messages</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Order processing</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Platforms</h3>
						<p class="step-desc">We integrate with eBay, Poshmark, Mercari, Depop, Facebook Marketplace, and more. All your selling in one place.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Import Your Inventory</h3>
						<p class="step-desc">Your AI catalogs your products, optimizes listings, and syncs across all connected platforms.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Sell on Autopilot</h3>
						<p class="step-desc">Within days, listings go live everywhere, prices adjust automatically, and orders process while you sleep.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Stop Juggling Platforms</h2>
				<p class="final-cta-sub">
					Let AI handle the chaos of multi-platform selling while you focus on sourcing and growth.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
