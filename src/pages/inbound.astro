---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faEnvelope, faComments, faDatabase, faClock, faCalendarDays, faArrowRightArrowLeft, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconEmail = icon(faEnvelope).html[0];
const iconChat = icon(faComments).html[0];
const iconCRM = icon(faDatabase).html[0];
const iconSpeed = icon(faClock).html[0];
const iconScheduling = icon(faCalendarDays).html[0];
const iconRouting = icon(faArrowRightArrowLeft).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Inbound Agent">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI-Powered Inbound</span></div>
				<h1 class="hero-heading">Never Miss Another Lead. <span class="accent">Qualify Inbound 24/7.</span></h1>
				<p class="hero-sub">
					An AI employee that lives in your email, chat, and CRM, responding to every inbound inquiry in minutes, qualifying leads, and booking meetings while you sleep.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">21x</span>
					<span class="hero-stat-label">Better conversion when you respond in 5 min vs 1 hour</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Leads sit in inbox for hours or days</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Sales reps cherry-pick the best leads</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Chat visitors leave before getting help</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No one works nights or weekends</span></div>
				</div>

				<p class="problem-callout">What if every single lead got a personalized response in under 5 minutes, 24/7/365?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI INBOUND AGENT DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Inbound Agent Does</h2>
				<p class="section-subtext">Instant response, intelligent qualification, and seamless handoff, all running autonomously on hardware you control.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconEmail}></div>
						<h3 class="role-card-title">Email Response in Minutes</h3>
						<p class="role-card-desc">Responds to inbound inquiries within 5 minutes, 24/7. Qualifies interest, answers questions, and routes hot leads.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconChat}></div>
						<h3 class="role-card-title">Live Chat Qualification</h3>
						<p class="role-card-desc">Handles website chat conversations, qualifies visitors based on your criteria, and books meetings for qualified prospects.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCRM}></div>
						<h3 class="role-card-title">CRM-Native</h3>
						<p class="role-card-desc">Lives inside your CRM. Creates leads, updates records, assigns owners, and triggers workflows automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconSpeed}></div>
						<h3 class="role-card-title">Speed to Lead</h3>
						<p class="role-card-desc">Responds in minutes, not hours. Studies show responding within 5 minutes is 21x more effective than waiting an hour.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconScheduling}></div>
						<h3 class="role-card-title">Instant Scheduling</h3>
						<p class="role-card-desc">Books qualified meetings directly on your AE calendars. No back-and-forth. No scheduling links. Just booked meetings.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRouting}></div>
						<h3 class="role-card-title">Intelligent Routing</h3>
						<p class="role-card-desc">Routes leads to the right rep based on territory, segment, product interest, or custom rules. No leads fall through cracks.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL INBOUND COVERAGE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full Inbound Coverage</h2>
				<p class="section-subtext">From first touch to booked meeting, your AI handles the entire inbound qualification process.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Email Qualification</h3>
						<ul class="value-list">
							<li>Monitor shared inboxes for new inquiries</li>
							<li>Qualify based on budget, authority, need, timeline</li>
							<li>Answer product and pricing questions</li>
							<li>Schedule follow-up sequences for nurturing</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Chat Engagement</h3>
						<ul class="value-list">
							<li>Engage website visitors in real-time</li>
							<li>Qualify through conversational Q&amp;A</li>
							<li>Hand off to human reps when needed</li>
							<li>Capture contact info for follow-up</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">CRM Management</h3>
						<ul class="value-list">
							<li>Create and enrich lead records</li>
							<li>Score leads based on qualification criteria</li>
							<li>Update contact and account information</li>
							<li>Trigger automated workflows and notifications</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Meeting Booking</h3>
						<ul class="value-list">
							<li>Access rep calendars in real-time</li>
							<li>Book meetings based on availability and rules</li>
							<li>Send calendar invites with context</li>
							<li>Handle rescheduling and cancellations</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== SPEED WINS DEALS ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Speed Wins Deals</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">&lt;5 min</span>
						<span class="stat-label">Average response time to inbound leads</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">40%</span>
						<span class="stat-label">Increase in lead-to-meeting conversion</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">100%</span>
						<span class="stat-label">Of leads get a response, 24/7</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">0</span>
						<span class="stat-label">Leads lost to slow follow-up</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Define Qualification Criteria</h3>
						<p class="step-desc">We map out your ICP, qualification questions, and routing rules together.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Connect Channels &amp; CRM</h3>
						<p class="step-desc">Your AI Inbound connects to email, chat, and CRM. Sees everything, responds everywhere.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Start Qualifying</h3>
						<p class="step-desc">Every inbound lead gets an immediate, personalized response. Qualified meetings start appearing.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Capture Every Lead?</h2>
				<p class="final-cta-sub">
					Tell us about your inbound volume and current process. We'll show you the leads you're missing.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
