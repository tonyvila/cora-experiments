---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faCommentDots, faWrench, faMoneyCheckDollar, faFileContract, faCalendarCheck, faChartLine, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconComms = icon(faCommentDots).html[0];
const iconMaintenance = icon(faWrench).html[0];
const iconRent = icon(faMoneyCheckDollar).html[0];
const iconLease = icon(faFileContract).html[0];
const iconShowings = icon(faCalendarCheck).html[0];
const iconReporting = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Employees for Property Management">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI for Property Management</span></div>
				<h1 class="hero-heading">Manage More Properties. <span class="accent">Without More Staff.</span></h1>
				<p class="hero-sub">
					Your AI property assistant handles tenant communication, maintenance coordination, rent collection, and leasing 24/7&nbsp;&mdash; freeing you to grow your portfolio.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">2x</span>
					<span class="hero-stat-label">Properties per property manager</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Tenant calls and texts never stop</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Maintenance coordination eats your day</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Chasing rent is a monthly nightmare</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No time for leasing and growth</span></div>
				</div>

				<p class="problem-callout">What if tenants got instant responses, maintenance handled itself, and rent collection was automatic?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI PROPERTY ASSISTANT DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Property Assistant Does</h2>
				<p class="section-subtext">Complete property management operations&nbsp;&mdash; tenant relations, maintenance, leasing&nbsp;&mdash; automated 24/7.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconComms}></div>
						<h3 class="role-card-title">Tenant Communication</h3>
						<p class="role-card-desc">Responds to tenant inquiries 24/7 via text, email, and portal. Handles maintenance requests, lease questions, and more.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconMaintenance}></div>
						<h3 class="role-card-title">Maintenance Coordination</h3>
						<p class="role-card-desc">Receives requests, triages urgency, dispatches vendors, and follows up on completion. Full work order lifecycle.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRent}></div>
						<h3 class="role-card-title">Rent Collection</h3>
						<p class="role-card-desc">Sends payment reminders, processes online payments, tracks delinquencies, and initiates collections workflows.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconLease}></div>
						<h3 class="role-card-title">Lease Administration</h3>
						<p class="role-card-desc">Tracks lease terms, renewal dates, and rent increases. Generates renewal letters and lease documents.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconShowings}></div>
						<h3 class="role-card-title">Showing Scheduling</h3>
						<p class="role-card-desc">Handles prospect inquiries, schedules showings, sends reminders, and follows up with leads automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReporting}></div>
						<h3 class="role-card-title">Financial Reporting</h3>
						<p class="role-card-desc">Generates owner statements, P&amp;L reports, and portfolio analytics. Monthly reporting on autopilot.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL-SERVICE PROPERTY MANAGEMENT ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full-Service Property Management</h2>
				<p class="section-subtext">From tenant inquiry to owner reporting, your AI covers it all.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Tenant Relations</h3>
						<ul class="value-list">
							<li>24/7 tenant communication</li>
							<li>Maintenance request handling</li>
							<li>Lease question responses</li>
							<li>Move-in/move-out coordination</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Operations</h3>
						<ul class="value-list">
							<li>Work order management</li>
							<li>Vendor coordination</li>
							<li>Inspection scheduling</li>
							<li>Compliance tracking</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Financial</h3>
						<ul class="value-list">
							<li>Rent collection and reminders</li>
							<li>Late fee processing</li>
							<li>Owner distributions</li>
							<li>Monthly financial reports</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Leasing</h3>
						<ul class="value-list">
							<li>Lead response and qualification</li>
							<li>Showing scheduling</li>
							<li>Application processing</li>
							<li>Lease generation and renewal</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Scale Without Hiring</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">70%</span>
						<span class="stat-label">Reduction in admin time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Tenant response coverage</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">98%</span>
						<span class="stat-label">On-time rent collection</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">2x</span>
						<span class="stat-label">Properties managed per PM</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Systems</h3>
						<p class="step-desc">We integrate with AppFolio, Buildium, Rent Manager, and more. Your property data stays in sync.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Operations</h3>
						<p class="step-desc">Set up your communication preferences, vendor list, and workflows. Your AI follows your process.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Scale Your Portfolio</h3>
						<p class="step-desc">Within days, tenant communication, maintenance, and leasing run themselves. Grow without hiring.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Your Portfolio Can Grow. Your Staff Doesn't Have To.</h2>
				<p class="final-cta-sub">
					Let AI handle the operations while you focus on acquiring and improving properties.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
