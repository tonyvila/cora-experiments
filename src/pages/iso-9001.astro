---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faFileLines, faClipboardList, faTriangleExclamation, faMagnifyingGlass, faGraduationCap, faChartLine, faArrowsRotate, faShieldHalved, faEye, faRocket } from '@fortawesome/pro-light-svg-icons';
const iconDocControl = icon(faFileLines).html[0];
const iconAuditTrail = icon(faClipboardList).html[0];
const iconCorrective = icon(faTriangleExclamation).html[0];
const iconAuditPrep = icon(faMagnifyingGlass).html[0];
const iconTraining = icon(faGraduationCap).html[0];
const iconCompliance = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
const iconAuditReady = icon(faShieldHalved).html[0];
const iconZeroNC = icon(faEye).html[0];
const iconImprovement = icon(faRocket).html[0];
---

<Layout title="Cora — AI for ISO 9001">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI for ISO 9001</span></div>
				<h1 class="hero-heading">Automate Compliance. <span class="accent">Ace Every Audit.</span></h1>
				<p class="hero-sub">
					An AI employee for ISO 9001 that handles document control, audit trails, and quality management&mdash;so you're always ready for ISO 9001:2026.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">70%</span>
					<span class="hero-stat-label">Reduction in audit preparation time</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Document version chaos and missing approvals</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Audit preparation consumes weeks of work</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Corrective actions fall through the cracks</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">ISO 9001:2026 migration feels overwhelming</span></div>
				</div>

				<p class="problem-callout">What if your QMS maintained itself, audit evidence appeared on demand, and compliance happened automatically in the background?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI ISO 9001 EMPLOYEE DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI ISO 9001 Employee Does</h2>
				<p class="section-subtext">Everything that makes ISO compliance painful: documentation, tracking, reporting, handled autonomously.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconDocControl}></div>
						<h3 class="role-card-title">Document Control</h3>
						<p class="role-card-desc">Automatically manages document versions, approval workflows, and distribution. Ensures only current documents are in use and tracks all changes for audit readiness.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAuditTrail}></div>
						<h3 class="role-card-title">Audit Trail Management</h3>
						<p class="role-card-desc">Maintains comprehensive, tamper-proof records of all quality activities. Automatically logs who did what, when, and why&mdash;ready for any auditor review.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCorrective}></div>
						<h3 class="role-card-title">Corrective Action Tracking</h3>
						<p class="role-card-desc">Monitors non-conformances from identification through root cause analysis to preventive action. Sends reminders, escalates overdue items, and verifies effectiveness.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAuditPrep}></div>
						<h3 class="role-card-title">Audit Preparation</h3>
						<p class="role-card-desc">Pre-audit readiness checks, automatic evidence collection, and mock audit simulations. Reduces auditor time on-site and minimizes findings.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTraining}></div>
						<h3 class="role-card-title">Training Records</h3>
						<p class="role-card-desc">Tracks employee training, certifications, and competency assessments. Automatically schedules refresher training and flags upcoming expirations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCompliance}></div>
						<h3 class="role-card-title">Compliance Reporting</h3>
						<p class="role-card-desc">Generates management review reports, KPI dashboards, and compliance scorecards. Real-time visibility into your quality management system health.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== BUILT FOR ISO 9001 EXCELLENCE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Built for ISO 9001 Excellence</h2>
				<p class="section-subtext">Deep understanding of quality management standards, from document control to continuous improvement.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">ISO 9001:2026 Migration</h3>
						<ul class="value-list">
							<li>Gap analysis against new standard requirements</li>
							<li>Document updates and version control</li>
							<li>Training on new processes and clauses</li>
							<li>Transition timeline management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Document Management</h3>
						<ul class="value-list">
							<li>Centralized document repository</li>
							<li>Automated review and approval workflows</li>
							<li>Distribution and acknowledgment tracking</li>
							<li>Obsolete document archival</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Quality Processes</h3>
						<ul class="value-list">
							<li>Non-conformance management</li>
							<li>CAPA (Corrective and Preventive Action)</li>
							<li>Internal audit scheduling and tracking</li>
							<li>Management review preparation</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Continuous Improvement</h3>
						<ul class="value-list">
							<li>KPI monitoring and alerts</li>
							<li>Process performance analysis</li>
							<li>Risk-based thinking integration</li>
							<li>Opportunity identification</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">70%</span>
						<span class="stat-label">Reduction in audit prep time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Compliance monitoring</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">100%</span>
						<span class="stat-label">Audit trail completeness</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">50%</span>
						<span class="stat-label">Faster document approvals</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Assess Current State</h3>
						<p class="step-desc">We analyze your existing QMS, documentation structure, and compliance gaps.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Your AI</h3>
						<p class="step-desc">Set up document workflows, approval chains, and compliance rules.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Achieve Compliance</h3>
						<p class="step-desc">Your AI maintains your QMS daily, prepares for audits automatically.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== READY FOR ISO 9001:2026 ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Ready for ISO 9001:2026</h2>
				<p class="section-subtext">The next revision of ISO 9001 is coming. Stay ahead of the changes.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">What's Changing in ISO 9001:2026</h3>
						<ul class="value-list">
							<li>Enhanced focus on climate change and sustainability</li>
							<li>Greater emphasis on risk-based thinking</li>
							<li>Expanded requirements for documented information</li>
							<li>Stronger alignment with other management system standards</li>
							<li>Updated terminology and structure</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">How AI Simplifies Migration</h3>
						<ul class="value-list">
							<li>Automated gap analysis identifies required changes</li>
							<li>Smart document migration preserves version history</li>
							<li>Training workflows ensure team readiness</li>
							<li>Continuous compliance monitoring prevents regression</li>
							<li>Audit-ready evidence from day one</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FROM COMPLIANCE BURDEN TO COMPETITIVE ADVANTAGE ===== -->
		<section class="section roles">
			<div class="container">
				<h2 class="section-title">From Compliance Burden to Competitive Advantage</h2>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAuditReady}></div>
						<h3 class="role-card-title">Always Audit-Ready</h3>
						<p class="role-card-desc">No more frantic preparation. Your QMS is continuously maintained with complete documentation and evidence ready for any audit.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconZeroNC}></div>
						<h3 class="role-card-title">Zero Non-Conformances</h3>
						<p class="role-card-desc">Proactive monitoring catches issues before they become findings. Automated workflows ensure nothing slips through the cracks.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconImprovement}></div>
						<h3 class="role-card-title">Continuous Improvement</h3>
						<p class="role-card-desc">Turn compliance data into insights. Identify trends, spot opportunities, and drive real quality improvement across your organization.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Automate Your ISO 9001 Compliance?</h2>
				<p class="final-cta-sub">
					Tell us about your current QMS and audit challenges. We'll show you exactly how AI can reduce your compliance burden and prepare you for ISO 9001:2026.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
