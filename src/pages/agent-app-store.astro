---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faLayerGroup, faShieldHalved, faBuilding, faChartLine, faMoneyCheckDollar, faCodeBranch, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconCatalog = icon(faLayerGroup).html[0];
const iconApproved = icon(faShieldHalved).html[0];
const iconDepartment = icon(faBuilding).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconChargeback = icon(faMoneyCheckDollar).html[0];
const iconVersion = icon(faCodeBranch).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — Agent App Store">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Enterprise AI App Store</span></div>
				<h1 class="hero-heading">Your AI Employee Catalog. Governed. Self-Service. <span class="accent">Scalable.</span></h1>
				<p class="hero-sub">
					Build an internal app store of pre-approved AI employees. IT stays in control, teams get what they need, and shadow AI becomes a thing of the past.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">80%</span>
					<span class="hero-stat-label">Faster AI deployment across teams</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Teams deploy AI tools without IT approval</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No visibility into AI spend across the org</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Every deployment requires IT involvement</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Shadow AI creates security and compliance risks</span></div>
				</div>

				<p class="problem-callout">What if teams could self-serve AI employees from an approved catalog&mdash;with full governance, visibility, and cost control?</p>
			</div>
		</section>

		<!-- ===== THE INTERNAL AI PLATFORM ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">The Internal AI Platform</h2>
				<p class="section-subtext">Give teams the AI they need while maintaining enterprise control.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCatalog}></div>
						<h3 class="role-card-title">Your Private Catalog</h3>
						<p class="role-card-desc">Build an internal app store of approved AI employees. IT controls what's available, teams self-serve what they need.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconApproved}></div>
						<h3 class="role-card-title">Pre-Approved &amp; Secure</h3>
						<p class="role-card-desc">Every agent in your app store has passed security review, compliance checks, and IT approval. No shadow AI.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconDepartment}></div>
						<h3 class="role-card-title">Department Management</h3>
						<p class="role-card-desc">Control which departments can access which agents. Sales gets SDRs, Finance gets bookkeepers. Clean separation.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Usage Analytics</h3>
						<p class="role-card-desc">See which agents are deployed where, usage patterns, and ROI by department. Make data-driven AI investments.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconChargeback}></div>
						<h3 class="role-card-title">Chargeback &amp; Budgeting</h3>
						<p class="role-card-desc">Allocate AI costs to departments. Set budgets, track spend, and automate chargebacks to cost centers.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconVersion}></div>
						<h3 class="role-card-title">Version Control</h3>
						<p class="role-card-desc">Manage agent versions across the organization. Test new versions with pilot groups before broad rollout.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== ENTERPRISE-READY FEATURES ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Enterprise-Ready Features</h2>
				<p class="section-subtext">Everything you need to manage AI employees at scale.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Catalog Management</h3>
						<ul class="value-list">
							<li>Import agents from public marketplace</li>
							<li>Add custom-developed agents</li>
							<li>Set visibility and access rules</li>
							<li>Manage agent descriptions and docs</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Request &amp; Approval</h3>
						<ul class="value-list">
							<li>Self-service agent requests</li>
							<li>Multi-level approval workflows</li>
							<li>Automatic provisioning on approval</li>
							<li>Request tracking and history</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Governance</h3>
						<ul class="value-list">
							<li>Department-level permissions</li>
							<li>Budget enforcement</li>
							<li>Compliance attestation</li>
							<li>Audit trail for all deployments</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Administration</h3>
						<ul class="value-list">
							<li>SSO and directory integration</li>
							<li>Usage dashboards</li>
							<li>Cost allocation reporting</li>
							<li>Bulk deployment tools</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">80%</span>
						<span class="stat-label">Reduction in AI deployment time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">0</span>
						<span class="stat-label">Shadow AI deployments</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">100%</span>
						<span class="stat-label">Visibility into AI spend</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">3x</span>
						<span class="stat-label">Faster time-to-value for teams</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Configure Your Store</h3>
						<p class="step-desc">Select which agents to include, set up department permissions, and configure approval workflows.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Enable Self-Service</h3>
						<p class="step-desc">Teams browse available agents, request what they need, and get approved agents deployed automatically.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Monitor &amp; Optimize</h3>
						<p class="step-desc">Track usage, measure ROI, and continuously improve your AI employee catalog based on real data.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Build Your AI Platform?</h2>
				<p class="final-cta-sub">
					Tell us about your organization and AI goals. We'll show you how an internal app store accelerates adoption while maintaining control.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
