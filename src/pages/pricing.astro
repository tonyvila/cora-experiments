<style>
	/* ===== Comparison Table ===== */
	.pp-compare-section {
		padding-top: 2rem;
	}

	.pp-table-wrap {
		overflow-x: clip;
	}

	.pp-table {
		width: 100%;
		min-width: 600px;
		border-collapse: separate;
		border-spacing: 0;
	}

	.pp-table th,
	.pp-table td {
		padding: 0.85rem 1.25rem;
		text-align: left;
		font-size: 0.9375rem;
		border-bottom: 1px solid var(--v2-border);
		width: 33.33%;
	}

	.pp-table thead {
		position: sticky;
		top: 64px;
		z-index: 10;
	}

	.pp-th-plan {
		vertical-align: bottom;
		padding: 2rem 1.25rem;
		border-bottom: 2px solid var(--v2-border);
		background: var(--v2-bg);
		transition: padding 0.3s ease;
	}

	.pp-th-plan + .pp-th-plan {
		border-left: 1px solid var(--v2-border);
	}

	.pp-th-soon {
		background: var(--v2-bg);
	}

	.pp-th-soon .pp-plan-header {
		opacity: 0.55;
	}

	/* ===== Plan header inside <th> ===== */
	.pp-plan-header {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 1.1rem;
		padding-bottom: 1.5rem;
		text-align: left;
		transition: gap 0.3s ease, padding-bottom 0.3s ease;
	}

	.pp-plan-badge {
