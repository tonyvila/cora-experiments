---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faRocket, faCalendar, faDiagramProject, faKey, faDesktop, faChartLine } from '@fortawesome/pro-light-svg-icons';
const iconRocket = icon(faRocket).html[0];
const iconCalendar = icon(faCalendar).html[0];
const iconDiagram = icon(faDiagramProject).html[0];
const iconKey = icon(faKey).html[0];
const iconDesktop = icon(faDesktop).html[0];
const iconChart = icon(faChartLine).html[0];
