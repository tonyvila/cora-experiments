	<script>
		const sentinel = document.getElementById('pp-sentinel');
		const thead = document.querySelector('.pp-table thead');
		const mobileHeaders = document.querySelectorAll('.pp-mobile-card > .pp-plan-header');

		function toggleStuck(container: Element, isStuck: boolean) {
			container.classList.toggle('is-stuck', isStuck);
			container.querySelectorAll('.pp-plan-desc, .pp-plan-badge').forEach((el) => {
				const htmlEl = el as HTMLElement;
				if (isStuck) {
					const h = htmlEl.offsetHeight;
					htmlEl.style.height = h + 'px';
					htmlEl.style.opacity = '1';
					htmlEl.offsetHeight; // force reflow
					htmlEl.style.height = '0';
					htmlEl.style.opacity = '0';
					htmlEl.style.overflow = 'hidden';
					htmlEl.style.minHeight = '0';
					htmlEl.style.margin = '0';
					htmlEl.style.padding = '0';
				} else {
					htmlEl.style.removeProperty('min-height');
					htmlEl.style.removeProperty('margin');
					htmlEl.style.removeProperty('padding');
					const h = htmlEl.scrollHeight;
					htmlEl.style.height = '0';
					htmlEl.style.opacity = '0';
					htmlEl.offsetHeight; // force reflow
					htmlEl.style.height = h + 'px';
					htmlEl.style.opacity = '1';
					htmlEl.addEventListener('transitionend', () => {
						htmlEl.style.removeProperty('height');
						htmlEl.style.removeProperty('opacity');
						htmlEl.style.removeProperty('overflow');
					}, { once: true });
				}
			});
			const cells = container.querySelectorAll('th').length
				? container.querySelectorAll('th')
				: [container];
			cells.forEach((el) => {
				const price = el.querySelector('[class*="pp-plan-price"]') as HTMLElement;
				if (price) price.style.transform = isStuck ? 'translateY(-0.7rem)' : '';
				const btn = (el.querySelector('a') || el.querySelector('[class*="btn-coming-soon"]')) as HTMLElement;
				if (btn) btn.style.transform = isStuck ? 'translateY(-1.4rem)' : '';
			});
		}

		if (sentinel && thead) {
			const observer = new IntersectionObserver(
				([entry]) => {
					toggleStuck(thead, !entry.isIntersecting);
				},
				{ threshold: 0, rootMargin: '-65px 0px 0px 0px' }
			);
			observer.observe(sentinel);
		}

		mobileHeaders.forEach((header) => {
			const card = header.closest('.pp-mobile-card');
			if (!card) return;
			const mobileSentinel = document.createElement('div');
			mobileSentinel.className = 'pp-mobile-sentinel';
			card.insertBefore(mobileSentinel, header);

			const observer = new IntersectionObserver(
				([entry]) => {
					toggleStuck(header, !entry.isIntersecting);
				},
				{ threshold: 0, rootMargin: '-65px 0px 0px 0px' }
			);
			observer.observe(mobileSentinel);
		});
	</script>

	<Footer />

