---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faUserPlus, faFilePen, faMagnifyingGlass, faCalendarCheck, faMoneyCheckDollar, faCommentDots, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconIntake = icon(faUserPlus).html[0];
const iconDrafting = icon(faFilePen).html[0];
const iconResearch = icon(faMagnifyingGlass).html[0];
const iconMatter = icon(faCalendarCheck).html[0];
const iconBilling = icon(faMoneyCheckDollar).html[0];
const iconComms = icon(faCommentDots).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Employees for Law Firms">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI for Law Firms</span></div>
				<h1 class="hero-heading">Bill More Hours. <span class="accent">Work Fewer Of Them.</span></h1>
				<p class="hero-sub">
					An AI employee for law firms that handles intake, drafts documents, tracks deadlines, and captures time&nbsp;&mdash; so attorneys can focus on practicing law.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">60%</span>
					<span class="hero-stat-label">Less time on document drafting</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Intake calls interrupt billable work</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Document drafting eats up attorney time</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Deadlines require constant vigilance</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Time entries slip through the cracks</span></div>
				</div>

				<p class="problem-callout">What if every lead became a client consultation, every document started half-done, and every deadline tracked itself?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI LEGAL EMPLOYEE DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Legal Employee Does</h2>
				<p class="section-subtext">Everything that keeps attorneys from practicing law&nbsp;&mdash; intake, drafting, admin&nbsp;&mdash; handled autonomously.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconIntake}></div>
						<h3 class="role-card-title">Client Intake</h3>
						<p class="role-card-desc">Responds to inquiries 24/7, conducts initial intake interviews, collects conflict information, and schedules consultations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconDrafting}></div>
						<h3 class="role-card-title">Document Drafting</h3>
						<p class="role-card-desc">Generates first drafts of contracts, pleadings, and correspondence. Attorneys review and refine, not start from scratch.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconResearch}></div>
						<h3 class="role-card-title">Legal Research</h3>
						<p class="role-card-desc">Searches case law, statutes, and regulations. Summarizes relevant precedents and identifies key arguments.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconMatter}></div>
						<h3 class="role-card-title">Matter Management</h3>
						<p class="role-card-desc">Tracks deadlines, manages calendars, and sends reminders. Never miss a statute of limitations or filing deadline.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconBilling}></div>
						<h3 class="role-card-title">Time &amp; Billing</h3>
						<p class="role-card-desc">Captures time entries from attorney activity, generates invoices, and follows up on outstanding receivables.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconComms}></div>
						<h3 class="role-card-title">Client Communication</h3>
						<p class="role-card-desc">Sends case updates, answers routine questions, and keeps clients informed without consuming attorney time.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== BUILT FOR LEGAL ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Built for Legal</h2>
				<p class="section-subtext">Deep understanding of legal workflows, from intake to invoice.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Intake &amp; Onboarding</h3>
						<ul class="value-list">
							<li>24/7 inquiry response and qualification</li>
							<li>Conflict of interest checking</li>
							<li>Engagement letter generation</li>
							<li>Document collection from clients</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Legal Work Product</h3>
						<ul class="value-list">
							<li>Contract and agreement drafting</li>
							<li>Pleading and motion templates</li>
							<li>Discovery response preparation</li>
							<li>Legal research memoranda</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Practice Management</h3>
						<ul class="value-list">
							<li>Court deadline calculation and tracking</li>
							<li>Calendar management across matters</li>
							<li>Task assignment and follow-up</li>
							<li>Document management and organization</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Business Operations</h3>
						<ul class="value-list">
							<li>Time entry capture and categorization</li>
							<li>Invoice generation and delivery</li>
							<li>Trust accounting compliance</li>
							<li>Accounts receivable management</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">60%</span>
						<span class="stat-label">Reduction in document drafting time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">0</span>
						<span class="stat-label">Missed deadlines</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">25%</span>
						<span class="stat-label">Increase in billable hours captured</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Client intake never stops</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Systems</h3>
						<p class="step-desc">Integrate with your practice management software, document systems, and billing platform.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Your Practice</h3>
						<p class="step-desc">Define matter types, document templates, and billing rates. Your AI learns your firm's standards.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Practice More, Admin Less</h3>
						<p class="step-desc">Intake flows in, documents get drafted, deadlines get tracked. Attorneys focus on practicing law.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Transform Your Practice?</h2>
				<p class="final-cta-sub">
					Tell us about your firm and practice areas. We'll show you exactly how AI can help you bill more and stress less.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
