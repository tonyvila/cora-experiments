---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faFileLines, faHandshake, faChartLine, faFileShield, faReceipt, faShieldHalved, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconPO = icon(faFileLines).html[0];
const iconVendor = icon(faHandshake).html[0];
const iconSpend = icon(faChartLine).html[0];
const iconContract = icon(faFileShield).html[0];
const iconInvoice = icon(faReceipt).html[0];
const iconCompliance = icon(faShieldHalved).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Procurement">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Built for Procurement Teams</span></div>
				<h1 class="hero-heading">Procurement <span class="accent">Without the Paper.</span></h1>
				<p class="hero-sub">
					Your AI procurement assistant handles POs, vendor management, invoice processing, and spend analysis&mdash;freeing your team for strategic sourcing.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">12%</span>
					<span class="hero-stat-label">Average savings on procurement spend</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">PO processing takes days, not minutes</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Invoices pile up waiting for matching</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No visibility into maverick spend</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Contract renewals sneak up on you</span></div>
				</div>

				<p class="problem-callout">What if every PO routed automatically, invoices matched themselves, and you had complete spend visibility?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI PROCUREMENT ASSISTANT DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Procurement Assistant Does</h2>
				<p class="section-subtext">Complete procure-to-pay automation&mdash;from requisition to payment, handled 24/7.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconPO}></div>
						<h3 class="role-card-title">Purchase Order Management</h3>
						<p class="role-card-desc">Creates, routes, and tracks POs automatically. Matches invoices to POs. Handles three-way matching.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconVendor}></div>
						<h3 class="role-card-title">Vendor Management</h3>
						<p class="role-card-desc">Tracks vendor performance, certifications, and contracts. Manages the entire vendor lifecycle.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconSpend}></div>
						<h3 class="role-card-title">Spend Analysis</h3>
						<p class="role-card-desc">Analyzes spending patterns, identifies savings opportunities, and tracks compliance with contracts.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconContract}></div>
						<h3 class="role-card-title">Contract Management</h3>
						<p class="role-card-desc">Tracks contract terms, renewal dates, and compliance. Alerts on upcoming renewals and expirations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconInvoice}></div>
						<h3 class="role-card-title">Invoice Processing</h3>
						<p class="role-card-desc">Captures invoices, extracts data, matches to POs, and routes for approval. No manual data entry.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCompliance}></div>
						<h3 class="role-card-title">Reporting &amp; Compliance</h3>
						<p class="role-card-desc">Generates procurement reports, tracks KPIs, and ensures policy compliance across all purchases.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== END-TO-END PROCUREMENT COVERAGE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">End-to-End Procurement Coverage</h2>
				<p class="section-subtext">From vendor onboarding to spend analysis, your AI has it covered.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Requisition to Payment</h3>
						<ul class="value-list">
							<li>Automated requisition routing</li>
							<li>PO creation and approval workflows</li>
							<li>Receipt and invoice matching</li>
							<li>Payment scheduling and tracking</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Vendor Relations</h3>
						<ul class="value-list">
							<li>Vendor onboarding automation</li>
							<li>Performance scorecarding</li>
							<li>Certificate and compliance tracking</li>
							<li>RFQ and bidding management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Contract Lifecycle</h3>
						<ul class="value-list">
							<li>Contract repository management</li>
							<li>Term and obligation tracking</li>
							<li>Renewal and expiration alerts</li>
							<li>Amendment management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Analytics &amp; Savings</h3>
						<ul class="value-list">
							<li>Spend categorization and analysis</li>
							<li>Savings opportunity identification</li>
							<li>Maverick spend detection</li>
							<li>Budget tracking and forecasting</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== PROCUREMENT EXCELLENCE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Procurement Excellence</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">12%</span>
						<span class="stat-label">Average procurement savings</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">75%</span>
						<span class="stat-label">Reduction in processing time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Zero</span>
						<span class="stat-label">Missed contract renewals</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">100%</span>
						<span class="stat-label">Spend visibility</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Systems</h3>
						<p class="step-desc">We integrate with your ERP, accounting software, and vendor portals. All procurement data in one place.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Workflows</h3>
						<p class="step-desc">Set up approval chains, spending limits, and vendor requirements. Your AI enforces your policies.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Optimize Procurement</h3>
						<p class="step-desc">Within days, POs route automatically, invoices match themselves, and savings opportunities surface.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Stop Drowning in POs and Invoices</h2>
				<p class="final-cta-sub">
					Let AI handle the transactional work while you focus on strategic sourcing and savings.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
