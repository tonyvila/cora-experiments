---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faClockRotateLeft, faEye, faMagnifyingGlass, faFileLines, faBell, faLock, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconHistory = icon(faClockRotateLeft).html[0];
const iconMonitoring = icon(faEye).html[0];
const iconSearch = icon(faMagnifyingGlass).html[0];
const iconReports = icon(faFileLines).html[0];
const iconAlerts = icon(faBell).html[0];
const iconTamperProof = icon(faLock).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — Audit Logging">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Enterprise Feature</span></div>
				<h1 class="hero-heading">See Everything <span class="accent">Your AI Does.</span></h1>
				<p class="hero-sub">
					Complete audit logging for every action your AI employee takes. Full transparency, compliance-ready, searchable and exportable.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">100%</span>
					<span class="hero-stat-label">Action visibility and traceability</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">AI systems operate as black boxes</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No visibility into what AI is doing</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Compliance auditors asking questions you can't answer</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Can't debug or understand AI decisions</span></div>
				</div>

				<p class="problem-callout">What if you had a complete, searchable record of everything your AI has ever done&mdash;with full context?</p>
			</div>
		</section>

		<!-- ===== COMPLETE VISIBILITY ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">Complete Visibility</h2>
				<p class="section-subtext">Every action logged. Every decision explained. Every outcome recorded.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconHistory}></div>
						<h3 class="role-card-title">Complete Action History</h3>
						<p class="role-card-desc">Every action your AI takes is logged with timestamp, context, and outcome. Full audit trail for compliance and review.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconMonitoring}></div>
						<h3 class="role-card-title">Real-Time Monitoring</h3>
						<p class="role-card-desc">Watch your AI work in real-time. See what it's doing, why, and what it plans to do next.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconSearch}></div>
						<h3 class="role-card-title">Searchable Logs</h3>
						<p class="role-card-desc">Search and filter logs by action type, time range, system, or outcome. Find what you need instantly.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReports}></div>
						<h3 class="role-card-title">Compliance Reports</h3>
						<p class="role-card-desc">Generate audit reports for security, healthcare, or internal compliance. Export in standard formats.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAlerts}></div>
						<h3 class="role-card-title">Anomaly Alerts</h3>
						<p class="role-card-desc">Get notified when your AI takes unusual actions or encounters unexpected situations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTamperProof}></div>
						<h3 class="role-card-title">Tamper-Proof Storage</h3>
						<p class="role-card-desc">Logs stored with cryptographic integrity. Immutable records that can't be altered or deleted.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== ENTERPRISE-GRADE AUDIT TRAIL ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Enterprise-Grade Audit Trail</h2>
				<p class="section-subtext">Built for compliance, designed for transparency.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Action Logging</h3>
						<ul class="value-list">
							<li>Every command and action recorded</li>
							<li>Input/output capture</li>
							<li>Decision reasoning logged</li>
							<li>Error and exception tracking</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Access Controls</h3>
						<ul class="value-list">
							<li>Role-based log access</li>
							<li>Audit of who viewed logs</li>
							<li>Sensitive data masking</li>
							<li>Retention policy enforcement</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Compliance Features</h3>
						<ul class="value-list">
							<li>Security audit report generation</li>
							<li>Healthcare audit trails</li>
							<li>Custom compliance templates</li>
							<li>Regulatory export formats</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Monitoring &amp; Alerts</h3>
						<ul class="value-list">
							<li>Real-time dashboards</li>
							<li>Anomaly detection</li>
							<li>Custom alert rules</li>
							<li>Integration with SIEM tools</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== TRUST THROUGH TRANSPARENCY ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Trust Through Transparency</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">100%</span>
						<span class="stat-label">Action visibility</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">90 days</span>
						<span class="stat-label">Default log retention</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">&lt;1s</span>
						<span class="stat-label">Search response time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Zero</span>
						<span class="stat-label">Compliance gaps</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Automatic Logging</h3>
						<p class="step-desc">Every Cora deployment includes comprehensive audit logging by default. No configuration required.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Retention</h3>
						<p class="step-desc">Set your retention policies, compliance requirements, and alert preferences.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Trust, But Verify</h3>
						<p class="step-desc">Access complete records of everything your AI has done. Perfect for audits, debugging, and peace of mind.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">AI You Can Audit</h2>
				<p class="final-cta-sub">
					Deploy AI with confidence knowing you can see and verify everything it does.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
