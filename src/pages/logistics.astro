---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faRoute, faTruckFast, faBoxesStacked, faFileLines, faHandshake, faChartLine, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconRoute = icon(faRoute).html[0];
const iconTracking = icon(faTruckFast).html[0];
const iconInventory = icon(faBoxesStacked).html[0];
const iconDocs = icon(faFileLines).html[0];
const iconCarrier = icon(faHandshake).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Employees for Logistics">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Built for Logistics Operations</span></div>
				<h1 class="hero-heading">Logistics That <span class="accent">Runs Itself.</span></h1>
				<p class="hero-sub">
					Your AI logistics coordinator handles routing, tracking, documentation, and carrier management 24/7&nbsp;&mdash; keeping shipments moving while you sleep.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">18%</span>
					<span class="hero-stat-label">Average reduction in logistics costs</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Inefficient routes burning fuel and time</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Shipment delays discovered too late</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Hours spent on documentation and data entry</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No visibility across carriers and modes</span></div>
				</div>

				<p class="problem-callout">What if every shipment was optimized, every delay predicted, and all documentation handled automatically?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI LOGISTICS COORDINATOR DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Logistics Coordinator Does</h2>
				<p class="section-subtext">Complete logistics operations management&nbsp;&mdash; routing, tracking, documentation&nbsp;&mdash; automated 24/7.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRoute}></div>
						<h3 class="role-card-title">Route Optimization</h3>
						<p class="role-card-desc">Optimizes delivery routes in real-time based on traffic, weather, and constraints. Reduces miles driven and fuel costs.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTracking}></div>
						<h3 class="role-card-title">Shipment Tracking</h3>
						<p class="role-card-desc">Monitors all shipments across carriers. Proactively alerts on delays. Keeps customers informed automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconInventory}></div>
						<h3 class="role-card-title">Inventory Visibility</h3>
						<p class="role-card-desc">Real-time inventory across all locations. Automated replenishment alerts. Prevents stockouts and overstock.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconDocs}></div>
						<h3 class="role-card-title">Documentation</h3>
						<p class="role-card-desc">Generates BOLs, commercial invoices, and customs documents. Maintains compliance documentation automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCarrier}></div>
						<h3 class="role-card-title">Carrier Management</h3>
						<p class="role-card-desc">Manages carrier relationships, rate negotiations, and performance tracking. Gets you the best rates automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Analytics &amp; Reporting</h3>
						<p class="role-card-desc">On-time delivery rates, cost per shipment, carrier performance. The metrics you need to optimize operations.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== END-TO-END LOGISTICS COVERAGE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">End-to-End Logistics Coverage</h2>
				<p class="section-subtext">From warehouse to last-mile delivery, your AI coordinates every step.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Transportation Management</h3>
						<ul class="value-list">
							<li>Multi-modal route optimization</li>
							<li>Carrier selection and booking</li>
							<li>Real-time tracking and visibility</li>
							<li>Delivery appointment scheduling</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Warehouse Operations</h3>
						<ul class="value-list">
							<li>Inventory management and visibility</li>
							<li>Order fulfillment coordination</li>
							<li>Receiving and put-away</li>
							<li>Pick, pack, and ship optimization</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Documentation &amp; Compliance</h3>
						<ul class="value-list">
							<li>Automated BOL generation</li>
							<li>Customs documentation</li>
							<li>Hazmat compliance</li>
							<li>Proof of delivery management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Analytics &amp; Optimization</h3>
						<ul class="value-list">
							<li>Cost analysis and benchmarking</li>
							<li>Carrier performance scorecards</li>
							<li>Network optimization</li>
							<li>Demand forecasting</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== LOGISTICS EXCELLENCE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Logistics Excellence</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">18%</span>
						<span class="stat-label">Reduction in logistics costs</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">99.2%</span>
						<span class="stat-label">On-time delivery rate</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">40%</span>
						<span class="stat-label">Less time on documentation</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Real-time</span>
						<span class="stat-label">Visibility across all shipments</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Systems</h3>
						<p class="step-desc">We integrate with your TMS, WMS, and carrier APIs. All your logistics data flows together.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Operations</h3>
						<p class="step-desc">Set up your shipping rules, carrier preferences, and business constraints. Your AI optimizes within your parameters.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Ship Smarter</h3>
						<p class="step-desc">Within days, see reduced costs, faster deliveries, and less manual work. Logistics on autopilot.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Your Supply Chain Doesn't Sleep. Neither Should Your Operations.</h2>
				<p class="final-cta-sub">
					Get AI-powered logistics that keeps everything moving, around the clock.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
