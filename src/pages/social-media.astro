---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faCalendarDays, faComments, faShieldHalved, faChartLine, faUsers, faRocket, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconCalendar = icon(faCalendarDays).html[0];
const iconReplies = icon(faComments).html[0];
const iconModeration = icon(faShieldHalved).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconInfluencer = icon(faUsers).html[0];
const iconTrending = icon(faRocket).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Social Media Operator">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI-Powered Social Media</span></div>
				<h1 class="hero-heading">Fire Your Social Media Manager. <span class="accent">Hire One That Never Clocks Out.</span></h1>
				<p class="hero-sub">
					An AI social media operator that creates content, replies to comments, moderates your community, and grows your following, all while you sleep.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">50+</span>
					<span class="hero-stat-label">Posts per week, zero burnout</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Social managers cost $60K+ and still miss comments</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Posting consistency dies when they take PTO</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Trolls and spam slip through the cracks</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">You can't scale presence without scaling headcount</span></div>
				</div>

				<p class="problem-callout">What if your social presence ran itself, posting consistently, replying instantly, and moderating 24/7?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI SOCIAL OPERATOR DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Social Operator Does</h2>
				<p class="section-subtext">Everything a social media manager does: content, community, moderation, running autonomously around the clock.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCalendar}></div>
						<h3 class="role-card-title">Content Calendar Automation</h3>
						<p class="role-card-desc">Plans, writes, and schedules posts across platforms. Maintains your brand voice consistently without manual input.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReplies}></div>
						<h3 class="role-card-title">Real-Time Reply Management</h3>
						<p class="role-card-desc">Monitors mentions and comments 24/7. Responds authentically to engagement and escalates issues that need human attention.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconModeration}></div>
						<h3 class="role-card-title">Content Moderation</h3>
						<p class="role-card-desc">Removes spam, flags inappropriate content, and enforces community guidelines across all your social channels.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Analytics &amp; Optimization</h3>
						<p class="role-card-desc">Tracks engagement, identifies top-performing content, and adjusts strategy automatically based on what works.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconInfluencer}></div>
						<h3 class="role-card-title">Influencer &amp; UGC Outreach</h3>
						<p class="role-card-desc">Identifies relevant creators, initiates partnership conversations, and manages influencer campaigns at scale.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTrending}></div>
						<h3 class="role-card-title">Trend Hijacking</h3>
						<p class="role-card-desc">Spots trending topics relevant to your brand and creates timely content to capitalize on viral moments in real-time.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL-STACK SOCIAL OPERATIONS ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full-Stack Social Operations</h2>
				<p class="section-subtext">From content creation to crisis management, your AI handles the entire social workflow.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Content Creation</h3>
						<ul class="value-list">
							<li>Generate platform-native posts for Twitter, LinkedIn, Instagram, TikTok</li>
							<li>Create carousel graphics and short-form video scripts</li>
							<li>Repurpose long-form content into social snippets</li>
							<li>A/B test headlines and hooks automatically</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Community Management</h3>
						<ul class="value-list">
							<li>Reply to comments within minutes, not hours</li>
							<li>Handle DM inquiries and route to sales</li>
							<li>Manage crisis communications in real-time</li>
							<li>Build relationships with top followers</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Growth Operations</h3>
						<ul class="value-list">
							<li>Identify and engage target audience members</li>
							<li>Execute strategic following and unfollowing</li>
							<li>Run hashtag and keyword strategies</li>
							<li>Coordinate cross-platform campaigns</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Reporting &amp; Intelligence</h3>
						<ul class="value-list">
							<li>Daily performance reports in Slack</li>
							<li>Competitor tracking and benchmarking</li>
							<li>Sentiment analysis across mentions</li>
							<li>Content performance attribution</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">50+</span>
						<span class="stat-label">Posts created per week across platforms</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">5min</span>
						<span class="stat-label">Average response time to comments</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">300%</span>
						<span class="stat-label">Increase in engagement rate</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Community never goes unmonitored</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Accounts</h3>
						<p class="step-desc">Link your social profiles, define your brand voice, and set content guidelines. We handle the rest.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Approve the Strategy</h3>
						<p class="step-desc">Review the AI-generated content calendar and moderation rules. Adjust as needed, then let it run.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Watch Engagement Soar</h3>
						<p class="step-desc">Your AI social media operator posts, replies, and engages 24/7. You focus on strategy, not execution.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Dominate Social?</h2>
				<p class="final-cta-sub">
					Tell us about your brand and current social strategy. We'll show you exactly what your AI operator can do.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
