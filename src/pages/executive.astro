---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faCalendarDays, faEnvelope, faClipboardList, faRocket, faMagnifyingGlass, faHandshake, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconCalendar = icon(faCalendarDays).html[0];
const iconEmail = icon(faEnvelope).html[0];
const iconMeetings = icon(faClipboardList).html[0];
const iconTravel = icon(faRocket).html[0];
const iconResearch = icon(faMagnifyingGlass).html[0];
const iconStakeholders = icon(faHandshake).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Executive Assistant">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Built for Busy Executives</span></div>
				<h1 class="hero-heading">Get 10 Hours Back <span class="accent">Every Week.</span></h1>
				<p class="hero-sub">
					Your AI executive assistant handles calendar, email, travel, and meeting prep&mdash;everything a great EA does, available 24/7 at a fraction of the cost.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">10hrs</span>
					<span class="hero-stat-label">Saved per week on administrative work</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Calendar a mess of overlapping meetings</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Inbox overflowing with emails you can't ignore</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Meeting prep done on the fly (or not at all)</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Good EAs cost $80-150k and are hard to find</span></div>
				</div>

				<p class="problem-callout">What if you had a dedicated assistant that never sleeps, never takes vacation, and costs a fraction of a human EA?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI EXECUTIVE ASSISTANT DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Executive Assistant Does</h2>
				<p class="section-subtext">Everything a great EA handles&mdash;calendar, email, travel, research&mdash;automated and always available.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCalendar}></div>
						<h3 class="role-card-title">Calendar Management</h3>
						<p class="role-card-desc">Schedules meetings, resolves conflicts, protects focus time, and sends reminders. Learns your preferences over time.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconEmail}></div>
						<h3 class="role-card-title">Email Triage</h3>
						<p class="role-card-desc">Filters, prioritizes, and drafts responses. Handles routine inquiries. Surfaces only what needs your attention.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconMeetings}></div>
						<h3 class="role-card-title">Meeting Prep &amp; Follow-Up</h3>
						<p class="role-card-desc">Compiles briefing docs before meetings. Takes notes during. Sends summaries and action items after.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTravel}></div>
						<h3 class="role-card-title">Travel Arrangements</h3>
						<p class="role-card-desc">Books flights, hotels, and transportation. Creates detailed itineraries. Handles changes and cancellations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconResearch}></div>
						<h3 class="role-card-title">Research &amp; Analysis</h3>
						<p class="role-card-desc">Researches companies, people, and topics on demand. Compiles reports and executive summaries.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconStakeholders}></div>
						<h3 class="role-card-title">Stakeholder Management</h3>
						<p class="role-card-desc">Tracks relationships, birthdays, and follow-ups. Suggests touchpoints. Maintains your professional network.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== COMPREHENSIVE EXECUTIVE SUPPORT ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Comprehensive Executive Support</h2>
				<p class="section-subtext">From scheduling to stakeholder management, your AI has you covered.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Calendar &amp; Scheduling</h3>
						<ul class="value-list">
							<li>Intelligent meeting scheduling</li>
							<li>Focus time protection</li>
							<li>Time zone coordination</li>
							<li>Recurring meeting management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Communication</h3>
						<ul class="value-list">
							<li>Email triage and prioritization</li>
							<li>Response drafting</li>
							<li>Meeting follow-ups</li>
							<li>Internal communications</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Travel &amp; Logistics</h3>
						<ul class="value-list">
							<li>Flight and hotel booking</li>
							<li>Ground transportation</li>
							<li>Itinerary management</li>
							<li>Expense tracking</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Research &amp; Preparation</h3>
						<ul class="value-list">
							<li>Meeting briefing documents</li>
							<li>Company and person research</li>
							<li>Market intelligence</li>
							<li>Presentation preparation</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== TIME IS YOUR MOST VALUABLE ASSET ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Time Is Your Most Valuable Asset</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">10hrs</span>
						<span class="stat-label">Saved per week on admin</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">90%</span>
						<span class="stat-label">Email handled without you</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">Zero</span>
						<span class="stat-label">Scheduling conflicts</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Availability</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Tools</h3>
						<p class="step-desc">We integrate with your calendar, email, and travel systems. Your AI learns your preferences immediately.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Train Your Preferences</h3>
						<p class="step-desc">Share your meeting preferences, communication style, and priorities. Your AI adapts to how you work.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Reclaim Your Time</h3>
						<p class="step-desc">Within days, admin work disappears. Focus on what only you can do. Your AI handles the rest.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Stop Doing Admin Work</h2>
				<p class="final-cta-sub">
					Your time is worth more than scheduling meetings and filtering emails. Let AI handle it.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
