---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faServer, faShieldHalved, faLock, faClipboardList, faNetworkWired, faRotateRight, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconIsolation = icon(faServer).html[0];
const iconCompliance = icon(faShieldHalved).html[0];
const iconEncrypted = icon(faLock).html[0];
const iconAuditTrail = icon(faClipboardList).html[0];
const iconNetwork = icon(faNetworkWired).html[0];
const iconDisaster = icon(faRotateRight).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — Secure Hosting">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Secure AI Infrastructure</span></div>
				<h1 class="hero-heading">Your AI Employee. <span class="accent">Your Isolated Hardware.</span></h1>
				<p class="hero-sub">
					Secure hosting on dedicated Apple Silicon. No shared tenancy, full audit trails, and enterprise-grade compliance&mdash;without managing your own hardware.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">99.99%</span>
					<span class="hero-stat-label">Uptime SLA with zero breaches</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Cloud AI services share infrastructure with everyone</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">You can't audit what happens to your data</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Compliance teams reject shared-tenancy solutions</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">On-prem AI requires expensive infrastructure teams</span></div>
				</div>

				<p class="problem-callout">What if you got dedicated hardware, full isolation, and enterprise compliance&mdash;without hiring an infrastructure team?</p>
			</div>
		</section>

		<!-- ===== SECURITY YOU CAN TRUST ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">Security You Can Trust</h2>
				<p class="section-subtext">Dedicated hardware, full isolation, and enterprise compliance built into every deployment.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconIsolation}></div>
						<h3 class="role-card-title">Hardware-Level Isolation</h3>
						<p class="role-card-desc">Each AI employee runs on dedicated Apple Silicon hardware. No shared tenancy, no noisy neighbors, no data leakage.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconCompliance}></div>
						<h3 class="role-card-title">Security certification roadmap</h3>
						<p class="role-card-desc">Our hosting infrastructure meets the highest security standards. Continuous monitoring and documented controls.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconEncrypted}></div>
						<h3 class="role-card-title">Encrypted Everything</h3>
						<p class="role-card-desc">Data encrypted at rest and in transit. Secure enclaves for credential storage. Zero-knowledge architecture where possible.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAuditTrail}></div>
						<h3 class="role-card-title">Full Audit Trail</h3>
						<p class="role-card-desc">Every action logged and attributed. Complete visibility into what your AI employee does, when, and why.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconNetwork}></div>
						<h3 class="role-card-title">Network Segmentation</h3>
						<p class="role-card-desc">Your AI employee's network is isolated from other tenants. Custom firewall rules, private subnets, and VPN options.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconDisaster}></div>
						<h3 class="role-card-title">Disaster Recovery</h3>
						<p class="role-card-desc">Automated backups, geo-redundant storage, and tested recovery procedures. Your AI employee is always available.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== ENTERPRISE-GRADE SECURITY ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Enterprise-Grade Security</h2>
				<p class="section-subtext">Multiple layers of protection for your AI infrastructure.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Infrastructure Security</h3>
						<ul class="value-list">
							<li>Cloud VPS or dedicated Mac hardware options</li>
							<li>Physical security in Tier 4 data centers</li>
							<li>Biometric access controls</li>
							<li>24/7 security monitoring</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Data Protection</h3>
						<ul class="value-list">
							<li>AES-256 encryption at rest</li>
							<li>TLS 1.3 in transit</li>
							<li>Hardware security modules for keys</li>
							<li>Data residency options (US, EU)</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Access Control</h3>
						<ul class="value-list">
							<li>SSO integration (Okta, Azure AD)</li>
							<li>Role-based access control</li>
							<li>Multi-factor authentication</li>
							<li>Session management and timeouts</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Compliance</h3>
						<ul class="value-list">
							<li>Security certification roadmap</li>
							<li>Healthcare-ready configuration</li>
							<li>GDPR data handling</li>
							<li>Custom compliance packages</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">99.99%</span>
						<span class="stat-label">Uptime SLA</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">0</span>
						<span class="stat-label">Data breaches since launch</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">&lt;1hr</span>
						<span class="stat-label">Recovery time objective</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Security operations center</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Provision Your Hardware</h3>
						<p class="step-desc">We spin up dedicated Apple Silicon hardware in our secure data center. Your environment, your isolation.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Configure Security</h3>
						<p class="step-desc">Set up SSO, network policies, and compliance requirements. We match your organization's security posture.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Deploy &amp; Monitor</h3>
						<p class="step-desc">Your AI employee goes live on secure infrastructure. Full audit trails and 24/7 monitoring included.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready for Secure AI?</h2>
				<p class="final-cta-sub">
					Tell us about your security and compliance requirements. We'll show you exactly how our secure hosting meets them.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
