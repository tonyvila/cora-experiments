---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faCalendarDays, faRocket, faHeartPulse, faFileLines, faPaperPlane, faUsers, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconRenewal = icon(faCalendarDays).html[0];
const iconExpansion = icon(faRocket).html[0];
const iconHealth = icon(faHeartPulse).html[0];
const iconQBR = icon(faFileLines).html[0];
const iconOutreach = icon(faPaperPlane).html[0];
const iconStakeholders = icon(faUsers).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Customer Success Manager">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI-Powered Customer Success</span></div>
				<h1 class="hero-heading">Never Lose a Renewal. <span class="accent">Grow Every Account.</span></h1>
				<p class="hero-sub">
					An AI customer success manager that tracks renewals, identifies expansion opportunities, and maintains relationships, so your CSMs can focus on strategy, not admin.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">95%</span>
					<span class="hero-stat-label">Renewal rate with proactive management</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Renewals sneak up on you</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Expansion opportunities get missed</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">CSMs are stretched too thin</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Customer health is a guessing game</span></div>
				</div>

				<p class="problem-callout">What if every account got proactive attention, every renewal started on time, and expansion signals were surfaced automatically?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI CSM DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI CSM Does</h2>
				<p class="section-subtext">Renewal management, expansion identification, and customer health monitoring, running on hardware you control.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRenewal}></div>
						<h3 class="role-card-title">Renewal Management</h3>
						<p class="role-card-desc">Tracks every renewal date, initiates outreach 90 days out, and manages the entire renewal process through close.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconExpansion}></div>
						<h3 class="role-card-title">Expansion Identification</h3>
						<p class="role-card-desc">Monitors usage patterns, identifies expansion signals, and surfaces upsell opportunities before customers ask.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconHealth}></div>
						<h3 class="role-card-title">Health Scoring</h3>
						<p class="role-card-desc">Calculates customer health scores from product usage, support tickets, and engagement signals. Prioritizes CSM attention.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconQBR}></div>
						<h3 class="role-card-title">QBR Preparation</h3>
						<p class="role-card-desc">Generates QBR decks automatically with usage stats, ROI metrics, success stories, and expansion recommendations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconOutreach}></div>
						<h3 class="role-card-title">Proactive Outreach</h3>
						<p class="role-card-desc">Sends check-in emails, shares relevant content, and maintains customer relationships between QBRs.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconStakeholders}></div>
						<h3 class="role-card-title">Stakeholder Tracking</h3>
						<p class="role-card-desc">Monitors champion changes, tracks stakeholder engagement, and alerts on relationship risks.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL CUSTOMER SUCCESS COVERAGE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full Customer Success Coverage</h2>
				<p class="section-subtext">From renewal to expansion, your AI handles the operational work that keeps customers happy and revenue growing.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Renewal Operations</h3>
						<ul class="value-list">
							<li>Track renewal dates across all accounts</li>
							<li>Initiate renewal conversations automatically</li>
							<li>Handle pricing and contract questions</li>
							<li>Escalate at-risk renewals to humans</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Expansion Revenue</h3>
						<ul class="value-list">
							<li>Monitor product usage for expansion signals</li>
							<li>Identify cross-sell opportunities</li>
							<li>Prepare expansion proposals</li>
							<li>Coordinate with sales on large expansions</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Customer Health</h3>
						<ul class="value-list">
							<li>Calculate real-time health scores</li>
							<li>Track product adoption metrics</li>
							<li>Monitor support ticket patterns</li>
							<li>Alert on declining engagement</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Relationship Management</h3>
						<ul class="value-list">
							<li>Send personalized check-ins</li>
							<li>Share relevant content and updates</li>
							<li>Track stakeholder changes</li>
							<li>Maintain engagement between meetings</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== PROTECT AND GROW REVENUE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Protect and Grow Revenue</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">95%+</span>
						<span class="stat-label">Renewal rate maintained</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">30%</span>
						<span class="stat-label">Increase in expansion revenue</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">2x</span>
						<span class="stat-label">More accounts per CSM</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">0</span>
						<span class="stat-label">Renewals missed due to oversight</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Map Your Accounts</h3>
						<p class="step-desc">We import your customer data, renewal dates, and current health metrics.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Connect Your Stack</h3>
						<p class="step-desc">Your AI CSM connects to CRM, product analytics, and support tools. Full visibility into customer health.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Manage Proactively</h3>
						<p class="step-desc">Renewals get initiated on time, expansion opportunities surface automatically, and no account falls through the cracks.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Scale Customer Success?</h2>
				<p class="final-cta-sub">
					Tell us about your customer portfolio and current CS challenges. We'll show you how to protect and grow every account.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
