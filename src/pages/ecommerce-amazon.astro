---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faFileLines, faBullseye, faBoxesStacked, faShieldHalved, faStar, faHeartPulse, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconListings = icon(faFileLines).html[0];
const iconPpc = icon(faBullseye).html[0];
const iconInventory = icon(faBoxesStacked).html[0];
const iconHijacker = icon(faShieldHalved).html[0];
const iconReviews = icon(faStar).html[0];
const iconHealth = icon(faHeartPulse).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Employees for Amazon Sellers">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">Built for Amazon Sellers</span></div>
				<h1 class="hero-heading">Scale Your Amazon Business. <span class="accent">Without Hiring An Agency.</span></h1>
				<p class="hero-sub">
					Your AI Amazon operator handles listings, PPC, inventory, and brand protection 24/7&nbsp;&mdash; the work of a full team at a fraction of the cost.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">27%</span>
					<span class="hero-stat-label">Average improvement in organic rankings</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Listings not optimized for current search trends</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">PPC campaigns bleeding money while you sleep</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Stockouts killing your momentum</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Hijackers and counterfeiters appearing unnoticed</span></div>
				</div>

				<p class="problem-callout">What if you had an Amazon expert watching every ASIN, every campaign, and every competitor move 24/7?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI AMAZON OPERATOR DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Amazon Operator Does</h2>
				<p class="section-subtext">Complete Amazon account management&nbsp;&mdash; listings, ads, inventory, and brand protection.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconListings}></div>
						<h3 class="role-card-title">Listing Optimization</h3>
						<p class="role-card-desc">Continuously tests titles, bullets, and descriptions. Monitors keyword rankings and adjusts for search visibility.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconPpc}></div>
						<h3 class="role-card-title">PPC Campaign Management</h3>
						<p class="role-card-desc">Manages Sponsored Products, Brands, and Display campaigns. Optimizes bids, discovers keywords, and controls ACoS.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconInventory}></div>
						<h3 class="role-card-title">Inventory Management</h3>
						<p class="role-card-desc">Monitors stock levels, forecasts demand, creates purchase orders, and manages FBA shipments to prevent stockouts.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconHijacker}></div>
						<h3 class="role-card-title">24/7 Hijacker Monitoring</h3>
						<p class="role-card-desc">Detects listing hijackers, counterfeiters, and unauthorized sellers immediately. Alerts you and initiates removal.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReviews}></div>
						<h3 class="role-card-title">Review Management</h3>
						<p class="role-card-desc">Monitors reviews across all ASINs. Responds to customer feedback. Identifies and reports fake reviews.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconHealth}></div>
						<h3 class="role-card-title">Account Health Monitoring</h3>
						<p class="role-card-desc">Tracks account health metrics, policy compliance, and performance targets. Addresses issues before they escalate.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL-STACK AMAZON MANAGEMENT ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full-Stack Amazon Management</h2>
				<p class="section-subtext">Everything you need to dominate on Amazon, automated and optimized.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Listing Management</h3>
						<ul class="value-list">
							<li>Keyword research and optimization</li>
							<li>A+ Content management</li>
							<li>Image and video optimization</li>
							<li>Variation and bundle strategy</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Advertising</h3>
						<ul class="value-list">
							<li>Sponsored Products campaigns</li>
							<li>Sponsored Brands and Display</li>
							<li>Bid optimization and budget management</li>
							<li>Search term analysis and negative keywords</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Operations</h3>
						<ul class="value-list">
							<li>FBA inventory planning</li>
							<li>Shipment creation and tracking</li>
							<li>Reimbursement claims</li>
							<li>Returns and refunds management</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Brand Protection</h3>
						<ul class="value-list">
							<li>Hijacker detection and removal</li>
							<li>MAP violation monitoring</li>
							<li>Counterfeit reporting</li>
							<li>Brand Registry management</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== RESULTS THAT COMPOUND ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Results That Compound</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">27%</span>
						<span class="stat-label">Average increase in organic rank</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">35%</span>
						<span class="stat-label">Reduction in ACoS</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">$0</span>
						<span class="stat-label">Lost to stockouts</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Brand protection</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Seller Central</h3>
						<p class="step-desc">We integrate directly with your Amazon Seller Central account. Full API access for complete control.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Analyze &amp; Strategize</h3>
						<p class="step-desc">Your AI audits listings, ads, and inventory. Identifies opportunities and creates optimization roadmap.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Execute &amp; Scale</h3>
						<p class="step-desc">Within days, see listings climb, ACoS drop, and sales grow. Your AI works 24/7 so you don't have to.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Your Competitors Have Teams. You Can Have AI.</h2>
				<p class="final-cta-sub">
					Level the playing field with an AI that works harder than any agency, 24/7.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
