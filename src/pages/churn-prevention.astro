---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faEye, faComments, faBell, faRocket, faClipboardList, faChartLine, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconUsage = icon(faEye).html[0];
const iconTickets = icon(faComments).html[0];
const iconWarning = icon(faBell).html[0];
const iconIntervention = icon(faRocket).html[0];
const iconPlaybook = icon(faClipboardList).html[0];
const iconAnalytics = icon(faChartLine).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Churn Prevention">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI-Powered Churn Prevention</span></div>
				<h1 class="hero-heading">See Churn Coming. <span class="accent">Stop It Before It Happens.</span></h1>
				<p class="hero-sub">
					An AI agent that monitors usage, analyzes support tickets, and identifies at-risk customers 60-90 days before they cancel, so you can intervene while there's still time.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">40%</span>
					<span class="hero-stat-label">Of at-risk customers saved with early intervention</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Churn surprises you at renewal</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">By the time you know, it's too late</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Can't monitor every customer manually</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">No consistent save process</span></div>
				</div>

				<p class="problem-callout">What if you knew which customers were about to churn 60-90 days in advance, and had an automated playbook to save them?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI CHURN AGENT DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Churn Agent Does</h2>
				<p class="section-subtext">Usage monitoring, risk scoring, and automated intervention, running on hardware you control with full visibility.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconUsage}></div>
						<h3 class="role-card-title">Usage Monitoring</h3>
						<p class="role-card-desc">Tracks product usage in real-time. Detects declining engagement, feature abandonment, and usage pattern changes that predict churn.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTickets}></div>
						<h3 class="role-card-title">Ticket Analysis</h3>
						<p class="role-card-desc">Monitors support tickets for frustration signals, repeated issues, and escalation patterns that indicate churn risk.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconWarning}></div>
						<h3 class="role-card-title">Early Warning System</h3>
						<p class="role-card-desc">Combines signals into a churn risk score. Alerts your team 60-90 days before a customer is likely to cancel.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconIntervention}></div>
						<h3 class="role-card-title">Automated Intervention</h3>
						<p class="role-card-desc">Initiates save campaigns automatically: personalized outreach, success manager alerts, and executive escalations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconPlaybook}></div>
						<h3 class="role-card-title">Playbook Execution</h3>
						<p class="role-card-desc">Runs proven save playbooks based on churn reason. Different approaches for pricing, product fit, and support issues.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAnalytics}></div>
						<h3 class="role-card-title">Retention Analytics</h3>
						<p class="role-card-desc">Tracks save rates, identifies patterns in churned customers, and continuously improves prediction accuracy.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== FULL CHURN PREVENTION COVERAGE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Full Churn Prevention Coverage</h2>
				<p class="section-subtext">From early detection to successful save, your AI handles the entire retention workflow.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Signal Detection</h3>
						<ul class="value-list">
							<li>Monitor daily/weekly active usage</li>
							<li>Track feature adoption and abandonment</li>
							<li>Analyze support ticket sentiment</li>
							<li>Detect login frequency changes</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Risk Scoring</h3>
						<ul class="value-list">
							<li>Calculate real-time churn probability</li>
							<li>Identify primary churn drivers</li>
							<li>Segment by risk level and reason</li>
							<li>Prioritize intervention opportunities</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Intervention</h3>
						<ul class="value-list">
							<li>Send automated check-in campaigns</li>
							<li>Alert CSMs to at-risk accounts</li>
							<li>Schedule executive outreach</li>
							<li>Offer targeted retention incentives</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Analysis &amp; Learning</h3>
						<ul class="value-list">
							<li>Track intervention success rates</li>
							<li>Identify patterns in saved customers</li>
							<li>Analyze lost customer feedback</li>
							<li>Continuously improve predictions</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== PROTECT YOUR REVENUE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Protect Your Revenue</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">60 days</span>
						<span class="stat-label">Average warning before churn</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">40%</span>
						<span class="stat-label">Of at-risk customers saved</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">3x</span>
						<span class="stat-label">ROI on retention investment</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">$0</span>
						<span class="stat-label">Wasted on customers already gone</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Data</h3>
						<p class="step-desc">We connect to your product analytics, support system, and CRM to build a complete customer picture.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Build Your Model</h3>
						<p class="step-desc">Your AI Churn Agent learns from your historical data to identify the signals that predict churn for YOUR customers.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Intervene Early</h3>
						<p class="step-desc">At-risk customers get flagged early. Save campaigns launch automatically. Your team focuses on the saves that matter.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Stop Churn?</h2>
				<p class="final-cta-sub">
					Tell us about your current churn rate and customer base. We'll show you how many customers you could save.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
