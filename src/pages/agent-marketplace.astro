---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faMagnifyingGlass, faShieldHalved, faRocket, faChartLine, faFileLines, faGear, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconBrowse = icon(faMagnifyingGlass).html[0];
const iconVerified = icon(faShieldHalved).html[0];
const iconDeploy = icon(faRocket).html[0];
const iconRatings = icon(faChartLine).html[0];
const iconLicensing = icon(faFileLines).html[0];
const iconContinuous = icon(faGear).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — Agent Marketplace">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI Employee Marketplace</span></div>
				<h1 class="hero-heading">Hire AI Employees. Already Trained. <span class="accent">Ready to Work.</span></h1>
				<p class="hero-sub">
					Browse and deploy pre-trained AI employees for every role. SDRs, bookkeepers, support agents&mdash;verified, certified, and ready to deliver results on day one.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">50+</span>
					<span class="hero-stat-label">Pre-trained AI employees ready to deploy</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Training AI from scratch takes months</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Custom development is expensive and risky</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">You don't know if it'll work until you try</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Every company reinvents the same wheels</span></div>
				</div>

				<p class="problem-callout">What if you could hire AI employees that are already trained, already tested, and already delivering results for companies like yours?</p>
			</div>
		</section>

		<!-- ===== THE AI HIRING PLATFORM ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">The AI Hiring Platform</h2>
				<p class="section-subtext">Find, evaluate, and deploy AI employees in minutes, not months.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconBrowse}></div>
						<h3 class="role-card-title">Browse Pre-Trained Employees</h3>
						<p class="role-card-desc">Find AI employees already trained for your industry and use case. SDRs, bookkeepers, support agents&mdash;ready to deploy.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconVerified}></div>
						<h3 class="role-card-title">Verified &amp; Certified</h3>
						<p class="role-card-desc">Every marketplace agent is tested and certified by our team. Performance benchmarks, security reviews, and quality guarantees.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconDeploy}></div>
						<h3 class="role-card-title">One-Click Deployment</h3>
						<p class="role-card-desc">Buy an agent and deploy it to your infrastructure in minutes. No configuration, no training, no waiting.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconRatings}></div>
						<h3 class="role-card-title">Performance Ratings</h3>
						<p class="role-card-desc">See how each agent performs across real deployments. Task completion rates, customer satisfaction, ROI metrics.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconLicensing}></div>
						<h3 class="role-card-title">Flexible Licensing</h3>
						<p class="role-card-desc">Monthly subscriptions, annual discounts, or perpetual licenses. Pay for what works for your business.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconContinuous}></div>
						<h3 class="role-card-title">Continuous Updates</h3>
						<p class="role-card-desc">Marketplace agents get ongoing improvements. New capabilities, better prompts, and performance optimizations&mdash;automatically.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== AGENTS FOR EVERY ROLE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Agents for Every Role</h2>
				<p class="section-subtext">Pre-trained AI employees across functions and industries.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Sales &amp; Marketing</h3>
						<ul class="value-list">
							<li>AI SDRs for outbound prospecting</li>
							<li>AI Marketing Ops for campaign management</li>
							<li>AI SEO specialists</li>
							<li>AI Social Media managers</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Operations</h3>
						<ul class="value-list">
							<li>AI Bookkeepers for QuickBooks/Xero</li>
							<li>AI HR coordinators</li>
							<li>AI Procurement specialists</li>
							<li>AI Executive Assistants</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Customer Success</h3>
						<ul class="value-list">
							<li>AI Support agents</li>
							<li>AI CSMs for account health</li>
							<li>AI Onboarding specialists</li>
							<li>AI Churn prevention agents</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Industry-Specific</h3>
						<ul class="value-list">
							<li>Real estate transaction coordinators</li>
							<li>Insurance CSRs</li>
							<li>Legal intake specialists</li>
							<li>Healthcare schedulers</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">50+</span>
						<span class="stat-label">Pre-trained AI employees available</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">5min</span>
						<span class="stat-label">Average time to deploy</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">4.8&#9733;</span>
						<span class="stat-label">Average customer rating</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">$0</span>
						<span class="stat-label">Upfront training costs</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Browse the Marketplace</h3>
						<p class="step-desc">Search by role, industry, or capability. Read reviews and performance metrics from other customers.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Purchase &amp; Deploy</h3>
						<p class="step-desc">Buy with one click. Agent deploys to your infrastructure immediately&mdash;on-prem or cloud-hosted.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Customize &amp; Scale</h3>
						<p class="step-desc">Fine-tune the agent with your specific data and preferences. Buy more agents as you grow.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Hire?</h2>
				<p class="final-cta-sub">
					Browse the marketplace and find your next AI employee. Deploy in minutes, see results in days.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
