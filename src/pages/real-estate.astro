---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faReply, faCalendarDays, faFileSignature, faRectangleList, faChartBar, faHandHoldingHeart, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconLeadResponse = icon(faReply).html[0];
const iconShowing = icon(faCalendarDays).html[0];
const iconTransaction = icon(faFileSignature).html[0];
const iconListing = icon(faRectangleList).html[0];
const iconMarket = icon(faChartBar).html[0];
const iconNurturing = icon(faHandHoldingHeart).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI Employees for Real Estate">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI for Real Estate</span></div>
				<h1 class="hero-heading">Every Lead Answered. <span class="accent">Every Deal on Track.</span></h1>
				<p class="hero-sub">
					An AI employee for real estate brokerages that responds to leads in 60 seconds, coordinates showings, and keeps every transaction moving to close.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">2x</span>
					<span class="hero-stat-label">More deals closed per agent</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>
				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Leads go cold while agents are in showings</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Transaction details slip through the cracks</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Agents spend more time on admin than selling</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Scaling means hiring more coordinators</span></div>
				</div>
				<p class="problem-callout">What if every lead got a response in under a minute, every showing got scheduled automatically, and every deal stayed on track to closing?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI REAL ESTATE EMPLOYEE DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI Real Estate Employee Does</h2>
				<p class="section-subtext">Everything that keeps agents from selling — lead response, coordination, admin — handled autonomously.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconLeadResponse}></div>
						<h3 class="role-card-title">Lead Response & Qualification</h3>
						<p class="role-card-desc">Responds to Zillow, Realtor.com, and website leads in under 60 seconds. Qualifies buyers and sellers 24/7.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconShowing}></div>
						<h3 class="role-card-title">Showing Coordination</h3>
						<p class="role-card-desc">Schedules showings, confirms appointments, and sends reminders. Coordinates multiple agents and properties.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconTransaction}></div>
						<h3 class="role-card-title">Transaction Coordination</h3>
						<p class="role-card-desc">Tracks contract milestones, chases signatures, and ensures nothing falls through the cracks to closing.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconListing}></div>
						<h3 class="role-card-title">Listing Management</h3>
						<p class="role-card-desc">Creates and syndicates listings, updates status across MLS and portals, and manages listing photos and descriptions.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconMarket}></div>
						<h3 class="role-card-title">Market Analysis</h3>
						<p class="role-card-desc">Pulls comps, generates CMAs, and tracks market trends. Gives agents instant data for pricing conversations.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconNurturing}></div>
						<h3 class="role-card-title">Client Nurturing</h3>
						<p class="role-card-desc">Maintains relationships with past clients and sphere. Sends market updates, home anniversaries, and check-ins.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== BUILT FOR REAL ESTATE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Built for Real Estate</h2>
				<p class="section-subtext">Deep understanding of real estate workflows, from first inquiry to closing table.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Lead Management</h3>
						<ul class="value-list">
							<li>Instant response to portal and website leads</li>
							<li>Buyer and seller qualification scripts</li>
							<li>Lead scoring and prioritization</li>
							<li>Long-term drip campaign execution</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Transaction Support</h3>
						<ul class="value-list">
							<li>Contract milestone tracking</li>
							<li>Document collection and management</li>
							<li>Closing coordination with all parties</li>
							<li>Post-closing follow-up automation</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Agent Productivity</h3>
						<ul class="value-list">
							<li>Calendar and showing management</li>
							<li>CRM updates and contact management</li>
							<li>Email and text drafting</li>
							<li>Social media content creation</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Brokerage Operations</h3>
						<ul class="value-list">
							<li>Agent onboarding and training support</li>
							<li>Commission tracking and splits</li>
							<li>Compliance and audit trail</li>
							<li>Performance reporting by agent</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== THE NUMBERS DON'T LIE ===== -->
		<section class="section">
			<div class="container">
				<h2 class="section-title">The Numbers Don't Lie</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">60sec</span>
						<span class="stat-label">Average lead response time</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">40%</span>
						<span class="stat-label">More showings booked per agent</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">2x</span>
						<span class="stat-label">Deals closed per agent</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">24/7</span>
						<span class="stat-label">Lead capture never stops</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Connect Your Systems</h3>
						<p class="step-desc">Integrate with your MLS, CRM, lead sources, and transaction management. We work with all major platforms.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Customize Your Workflows</h3>
						<p class="step-desc">Define your qualification criteria, showing protocols, and communication style. Your AI learns your brokerage's way.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Scale Your Business</h3>
						<p class="step-desc">Leads get worked instantly, showings get scheduled, and transactions stay on track. Agents close more deals.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready to Scale Your Brokerage?</h2>
				<p class="final-cta-sub">
					Tell us about your brokerage and current pain points. We'll show you exactly how AI can help you close more deals.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
