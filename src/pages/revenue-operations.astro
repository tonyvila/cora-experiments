---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReserveButton from '../components/ReserveButton.astro';
import { icon } from '@fortawesome/fontawesome-svg-core';
import { faDatabase, faLayerGroup, faTriangleExclamation, faRocket, faChartLine, faArrowRightArrowLeft, faArrowsRotate } from '@fortawesome/pro-light-svg-icons';
const iconHygiene = icon(faDatabase).html[0];
const iconAttribution = icon(faLayerGroup).html[0];
const iconPipeline = icon(faTriangleExclamation).html[0];
const iconAutomation = icon(faRocket).html[0];
const iconReporting = icon(faChartLine).html[0];
const iconIntegration = icon(faArrowRightArrowLeft).html[0];
const iconUpdated = icon(faArrowsRotate).html[0];
---

<Layout title="Cora — AI RevOps">

	<Navbar />

	<main>

		<!-- ===== HERO ===== -->
		<section class="hero" id="hero">
			<div class="container hero-container hero-container-wide">
				<div class="hero-pill"><span class="hero-pill-dot"></span><span class="hero-pill-text">AI-Powered RevOps</span></div>
				<h1 class="hero-heading">Clean Data. Clear Attribution. <span class="accent">RevOps That Runs Itself.</span></h1>
				<p class="hero-sub">
					An AI employee that maintains your CRM, tracks attribution, and keeps your pipeline honest, so your team can focus on selling, not data entry.
				</p>
				<div class="hero-stat">
					<span class="hero-stat-number">95%</span>
					<span class="hero-stat-label">Data accuracy maintained automatically</span>
				</div>
				<div class="hero-buttons">
					<ReserveButton />
					<a href="#how-it-works" class="btn btn-outline">See How It Works</a>
				</div>

				<div class="hw-wrap">
					<div class="hw-glow"></div>
					<div class="hw-box">
						<div class="hw-vents hw-vents-left">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-center">
							<div class="hw-logo">
								<svg width="11" height="13" viewBox="0 0 24 28" fill="rgba(139,94,60,0.4)" xmlns="http://www.w3.org/2000/svg"><path d="M20.8 17.7c-.3.7-.7 1.4-1.1 2-.6.9-1.1 1.5-1.5 1.9-.6.6-1.3 1-2 1-.5 0-1.1-.2-1.9-.5-.7-.3-1.4-.5-2-.5-.6 0-1.3.2-2 .5-.7.3-1.3.5-1.8.5-.7 0-1.4-.3-2-1-.4-.4-.9-1-1.5-1.9-.7-.9-1.2-2-1.6-3.2-.5-1.3-.7-2.5-.7-3.7 0-1.4.3-2.5.9-3.5.5-.8 1.1-1.4 1.9-1.8.8-.5 1.6-.7 2.5-.7.5 0 1.2.2 2 .5.8.4 1.3.5 1.5.5.2 0 .7-.2 1.7-.6.8-.4 1.5-.5 2.1-.4 1.6.1 2.7.8 3.5 2-1.4.9-2.1 2.1-2.1 3.6 0 1.2.4 2.3 1.3 3.1.4.4.8.7 1.3.9-.1.3-.2.6-.4 1zM16.5 2c0 1-.3 1.9-1 2.7-.8 1-1.8 1.6-2.9 1.5 0-.1 0-.2 0-.3 0-.9.4-1.9 1-2.7.3-.4.8-.7 1.3-1 .6-.3 1.1-.4 1.5-.5.1.1.1.2.1.3z"/></svg>
							</div>
						</div>
						<div class="hw-vents hw-vents-right">
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
							<div class="hw-vent"></div>
						</div>
						<div class="hw-power"></div>
					</div>
				</div>
				<p class="hero-hw-note">Runs on dedicated hardware: your office or the cloud. <span style="color: var(--v2-accent); font-weight: 500;">Always upgraded to the latest AI.</span></p>
			</div>
		</section>

		<!-- ===== THE PROBLEM ===== -->
		<section class="section value-prop">
			<div class="container">
				<h2 class="section-title">The Problem</h2>

				<div class="problem-grid">
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">CRM data decays 30% per year</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Attribution is a black box</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">Pipeline reviews are based on fiction</span></div>
					<div class="problem-item"><span class="problem-dot"></span><span class="problem-text">RevOps is always underwater</span></div>
				</div>

				<p class="problem-callout">What if your CRM cleaned itself, attribution was always accurate, and your forecast was actually trustworthy?</p>
			</div>
		</section>

		<!-- ===== WHAT YOUR AI REVOPS DOES ===== -->
		<section class="section roles" id="how-it-works">
			<div class="container">
				<h2 class="section-title">What Your AI RevOps Does</h2>
				<p class="section-subtext">Data hygiene, attribution tracking, and pipeline management, running continuously on hardware you control.</p>
				<div class="roles-grid">
					<div class="role-card">
						<div class="role-card-icon" set:html={iconHygiene}></div>
						<h3 class="role-card-title">CRM Data Hygiene</h3>
						<p class="role-card-desc">Cleans duplicates, fills missing fields, standardizes formats, and maintains data quality automatically.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAttribution}></div>
						<h3 class="role-card-title">Attribution Tracking</h3>
						<p class="role-card-desc">Tracks every touchpoint across the buyer journey. Attributes revenue to campaigns, channels, and content accurately.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconPipeline}></div>
						<h3 class="role-card-title">Pipeline Hygiene</h3>
						<p class="role-card-desc">Identifies stale deals, updates close dates, flags at-risk opportunities, and keeps your forecast honest.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconAutomation}></div>
						<h3 class="role-card-title">Process Automation</h3>
						<p class="role-card-desc">Automates lead routing, territory assignment, deal stage updates, and notification workflows.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconReporting}></div>
						<h3 class="role-card-title">Reporting &amp; Insights</h3>
						<p class="role-card-desc">Generates daily, weekly, and monthly reports. Surfaces insights about pipeline health, rep performance, and forecast accuracy.</p>
					</div>
					<div class="role-card">
						<div class="role-card-icon" set:html={iconIntegration}></div>
						<h3 class="role-card-title">Integration Management</h3>
						<p class="role-card-desc">Keeps data synced across your tech stack. Salesforce, HubSpot, Marketo, Outreach, all in harmony.</p>
					</div>
				</div>
				<div class="roles-footer-card">
				<div class="roles-footer-icon" set:html={iconUpdated}></div>
				<h3 class="roles-footer-title">Always Updated</h3>
				<p class="roles-footer-text">AI moves fast. We keep up so you don't have to. Automatic upgrades to the latest models, new capabilities as they ship. No AI expertise required on your team.</p>
			</div>
			</div>
		</section>

		<!-- ===== COMPLETE REVOPS COVERAGE ===== -->
		<section class="section features">
			<div class="container">
				<h2 class="section-title">Complete RevOps Coverage</h2>
				<p class="section-subtext">From data quality to revenue attribution, your AI handles the operational work that keeps revenue teams efficient.</p>
				<div class="value-grid-4">
					<div class="value-card">
						<h3 class="value-card-title">Data Quality</h3>
						<ul class="value-list">
							<li>Deduplicate contacts and accounts</li>
							<li>Enrich records with firmographic data</li>
							<li>Standardize field values and formats</li>
							<li>Flag and fix data anomalies</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Attribution &amp; Analytics</h3>
						<ul class="value-list">
							<li>Multi-touch attribution modeling</li>
							<li>Campaign ROI tracking</li>
							<li>Channel performance analysis</li>
							<li>Revenue influence reporting</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Pipeline Operations</h3>
						<ul class="value-list">
							<li>Stage movement validation</li>
							<li>Close date accuracy enforcement</li>
							<li>Stale deal identification</li>
							<li>Forecast accuracy tracking</li>
						</ul>
					</div>
					<div class="value-card">
						<h3 class="value-card-title">Process Automation</h3>
						<ul class="value-list">
							<li>Lead scoring and routing</li>
							<li>Territory assignment</li>
							<li>Notification and alert workflows</li>
							<li>SLA tracking and enforcement</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== OPERATIONS WITHOUT THE OVERHEAD ===== -->
		<section class="section stats">
			<div class="container">
				<h2 class="section-title">Operations Without the Overhead</h2>
				<div class="stats-grid">
					<div class="stat-item">
						<span class="stat-number">95%+</span>
						<span class="stat-label">CRM data accuracy maintained</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">20hrs</span>
						<span class="stat-label">Manual ops work saved per week</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">3x</span>
						<span class="stat-label">Better attribution visibility</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">$0</span>
						<span class="stat-label">Wasted on bad data decisions</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== HOW IT WORKS ===== -->
		<section class="next-steps">
			<div class="container">
				<h2 class="accent-heading">How It Works</h2>
				<div class="steps-grid">
					<div class="step-card">
						<span class="step-number">1</span>
						<h3 class="step-title">Audit Your Stack</h3>
						<p class="step-desc">We analyze your current CRM health, data flows, and operational processes together.</p>
					</div>
					<div class="step-card">
						<span class="step-number">2</span>
						<h3 class="step-title">Connect &amp; Configure</h3>
						<p class="step-desc">Your AI RevOps connects to CRM, marketing automation, and sales tools. Sets up rules and workflows.</p>
					</div>
					<div class="step-card">
						<span class="step-number">3</span>
						<h3 class="step-title">Maintain Automatically</h3>
						<p class="step-desc">Continuous cleaning, monitoring, and optimization. Your data stays accurate without manual effort.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ===== FINAL CTA ===== -->
		<section class="section final-cta" id="final-cta">
			<div class="container final-cta-container">
				<h2 class="final-cta-heading">Ready for Clean Data?</h2>
				<p class="final-cta-sub">
					Tell us about your current tech stack and biggest RevOps pain points. We'll show you the path to operational excellence.
				</p>
				<ReserveButton size="lg" />
			</div>
		</section>

	</main>

	<Footer />

</Layout>
